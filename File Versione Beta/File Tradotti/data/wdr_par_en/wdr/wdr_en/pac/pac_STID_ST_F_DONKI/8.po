msgctxt "1036"
msgid "Could we stop here a moment?"
msgstr "Potremmo fermarci un attimo?"

msgctxt "1048"
msgid "That shop looks interesting."
msgstr "Quel negozio sembra interessante."

msgctxt "1060"
msgid "Those tebasaki look delicious!"
msgstr "Quei tebasaki sembrano deliziosi!"

msgctxt "1072"
msgid "Ooh, cocktails."
msgstr "Ooh, dei cocktail."

msgctxt "1084"
msgid "Shall we play pool?"
msgstr "Ti va una partita a biliardo?"

msgctxt "1096"
msgid "That udon looks delicious!"
msgstr "Quell'udon sembra delizioso!"

msgctxt "1108"
msgid "Shall we play Taiko No Tatsujin?"
msgstr "Ti va di giocare a Taiko No Tatsujin?"

msgctxt "1120"
msgid "Shall we try the photo booth?"
msgstr "Proviamo la cabina per le foto?"

msgctxt "1132"
msgid "I'd love a stuffed animal."
msgstr "Mi piacerebbe un peluche."

msgctxt "1144"
msgid "Karaoke sounds fun!"
msgstr "Il karaoke sembra divertente!"

msgctxt "1156"
msgid "I'm famished."
msgstr "Sto morendo di fame."

msgctxt "1168"
msgid "I'm bored. Can we do something?"
msgstr "Mi annoio. Possiamo fare qualcosa?"

msgctxt "1180"
msgid "I'm exhausted."
msgstr "Sono esausto."

msgctxt "1192"
msgid "Shall we play pool?"
msgstr "Ti va una partita a biliardo?"

msgctxt "1204"
msgid "That was fun!"
msgstr "È stato divertente!"

msgctxt "1216"
msgid "Shall we play Taiko No Tatsujin?"
msgstr "Ti va di giocare a Taiko No Tatsujin?"

msgctxt "1228"
msgid "That was fun!"
msgstr "È stato divertente!"

msgctxt "1240"
msgid "Want to use the photo booth?"
msgstr "Ti va di usare la cabina per le foto?"

msgctxt "1252"
msgid "Now we have a lovely keepsake!"
msgstr "Ora abbiamo un bel ricordo!"

msgctxt "1264"
msgid ""
"Could you get me that odd\r\n"
"looking purple one?"
msgstr ""
"Potresti prendermi quello viola\n"
"dall'aria un po' strana?"

msgctxt "1276"
msgid "Thank you!"
msgstr "Grazie!"

