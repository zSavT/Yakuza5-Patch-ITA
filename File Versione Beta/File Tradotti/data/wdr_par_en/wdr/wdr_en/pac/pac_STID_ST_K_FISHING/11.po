msgctxt "124"
msgid "You did it, Uncle Kaz!"
msgstr "Ce l'hai fatta, zio Kaz!"

msgctxt "148"
msgid "Aw. What a shame."
msgstr "Oh. Che peccato."

msgctxt "172"
msgid ""
"Uncle Kaz! I betcha can't catch an <Color:8>oarfish<Color:Default>! Oar can "
"you? Hehe!"
msgstr ""
"Zio Kaz! Scommetto che non riesci a pescare un <Color:8>pesce "
"remo<Color:Default>! O forse sì? Hehe!"
