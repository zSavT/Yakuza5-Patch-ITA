msgctxt "288"
msgid ""
"Hah! There's no\r\n"
"way I'll lose!"
msgstr ""
"Ah! Non c'è modo\n"
"che io perda!"

msgctxt "324"
msgid "How did I lose that one?"
msgstr "Ma come ho fatto a perdere?"

msgctxt "336"
msgid ""
"Must've been practicing\r\n"
"behind my back."
msgstr ""
"Devi esserti allenato\n"
"alle mie spalle."

msgctxt "348"
msgid "I need to step up my game."
msgstr "Devo mettermi d'impegno."

msgctxt "360"
msgid "I'm getting pretty good!"
msgstr "Sto diventando proprio bravo!"

msgctxt "396"
msgid ""
"I lost to someone who\r\n"
"didn't even play well."
msgstr ""
"Ho perso contro uno che\n"
"non sapeva nemmeno giocare bene."

msgctxt "408"
msgid "This sucks..."
msgstr "Che schifo..."

msgctxt "420"
msgid "Hah! Guess I'm getting better."
msgstr "Ah! Mi sa che sto migliorando."
