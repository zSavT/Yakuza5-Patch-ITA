msgctxt "104"
msgid "Hey, Shinada! Stop runnin' off alone and help me out here!"
msgstr "Ehi, Shinada! Smettila di correre via da solo e dammi una mano qui!"

msgctxt "116"
msgid "Hey, Saejima-san! Can you come help me instead of running ahead!?"
msgstr "Ehi, Saejima-san! Invece di correre avanti, puoi venire ad aiutarmi!?"

