msgctxt "92"
msgid "(Ugh, blew it. Bastard ran away...)"
msgstr "(Ugh, ho toppato. Quel bastardo è scappato...)"

msgctxt "104"
msgid "(Can't give up. There's still time.)"
msgstr "(Non posso mollare. C'è ancora tempo.)"

msgctxt "128"
msgid "*pant* *huff*"
msgstr "*pant* *anf*"

msgctxt "140"
msgid "So... this is what it's like to kill a bear."
msgstr "Quindi... è questo che si prova a uccidere un orso."

msgctxt "152"
msgid "(Gotta scoop up the bear bile and take it back to the village.)"
msgstr "(Devo recuperare la bile d'orso e riportarla al villaggio.)"

msgctxt "1304"
msgid "Saejima"
msgstr "Saejima"
