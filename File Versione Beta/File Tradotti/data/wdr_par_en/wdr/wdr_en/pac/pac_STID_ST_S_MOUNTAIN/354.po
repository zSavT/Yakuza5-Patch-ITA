msgctxt "60"
msgid ""
"That's the way we came. Don't you want to bag something today? Then keep "
"looking for deer tracks."
msgstr ""
"Siamo arrivati da lì. Non vuoi abbattere niente oggi? Allora continua a "
"cercare tracce di cervo."

msgctxt "72"
msgid "(Got separated from Okudera-han. Better go back for 'im.)"
msgstr ""
"(Mi sono separato da Okudera-han. Meglio tornare indietro a prenderlo.)"

msgctxt "572"
msgid "Okudera"
msgstr "Okudera"

