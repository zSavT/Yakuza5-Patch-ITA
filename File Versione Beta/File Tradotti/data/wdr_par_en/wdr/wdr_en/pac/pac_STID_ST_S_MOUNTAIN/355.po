msgctxt "76"
msgid "Saejima, that's not the way to the hunting hut."
msgstr "Saejima, non è quella la strada per il capanno da caccia."

msgctxt "88"
msgid ""
"You're not ready to go that way yet. Keep looking for deer tracks elsewhere."
msgstr ""
"Non sei ancora pronto per andare da quella parte. Continua a cercare tracce "
"di cervo altrove."

msgctxt "100"
msgid "(Got separated from Okudera-han. Better go back for 'im.)"
msgstr ""
"(Mi sono separato da Okudera-han. Meglio tornare indietro a prenderlo.)"

msgctxt "752"
msgid "Okudera"
msgstr "Okudera"

msgctxt "756"
msgid "Saejima"
msgstr "Saejima"
