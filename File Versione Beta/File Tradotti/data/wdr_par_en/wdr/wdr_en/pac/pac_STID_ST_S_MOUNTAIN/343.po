msgctxt "76"
msgid "(Can't give up on nabbin' a bear now!)"
msgstr "(Mica posso rinunciare a beccare un orso proprio ora!)"

msgctxt "88"
msgid "(Oughta still be a bear around...)"
msgstr "(Dovrebbe esserci ancora un orso nei paraggi...)"

msgctxt "100"
msgid "(Gotta collect the bear bile now. Yuck...)"
msgstr "(Ora devo raccogliere la bile d'orso. Che schifo...)"
