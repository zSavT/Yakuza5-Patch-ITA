msgctxt "168"
msgid "(That's seven. Just one left.)"
msgstr "(E con questo sono sette. Ne manca solo uno.)"

msgctxt "180"
msgid "(That's six. Two more.)"
msgstr "(Siamo a sei. Ne mancano due.)"

msgctxt "192"
msgid "(That's the fifth one.)"
msgstr "(E con questo sono cinque.)"

msgctxt "204"
msgid "(That's four. Finally halfway there.)"
msgstr "(Siamo a quattro. Finalmente a metà strada.)"

msgctxt "216"
msgid "(That's number three.)"
msgstr "(E siamo a tre.)"

msgctxt "228"
msgid "(That's two. Still got a long ways to go.)"
msgstr "(Siamo a due. La strada è ancora lunga.)"

msgctxt "240"
msgid "(Well, that's a start.)"
msgstr "(Beh, è un inizio.)"

msgctxt "2652"
msgid "Saejima"
msgstr "Saejima"
