msgctxt "76"
msgid ""
"Saejima, where are you going? Get closer to the game. Don't forget to stay "
"in a crouch!"
msgstr ""
"Saejima, dove stai andando? Avvicinati alla preda. Non dimenticare di "
"restare accovacciato!"

msgctxt "88"
msgid "Saejima, what are you doing? Reload your gun."
msgstr "Saejima, che stai facendo? Ricarica il fucile."

msgctxt "100"
msgid "Saejima, what are you doing? Shoot that boulder across the river."
msgstr ""
"Saejima, che stai combinando? Spara a quel masso dall'altra parte del fiume."

msgctxt "840"
msgid "Okudera"
msgstr "Okudera"
