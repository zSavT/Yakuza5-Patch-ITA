msgctxt "60"
msgid "Takasugi-san! I'll buy us some time. You go on ahead!"
msgstr "Takasugi-san! Vi farò guadagnare tempo. Lei vada avanti!"

msgctxt "72"
msgid ""
"Tch! Don't try to be a hero, man.\r\n"
"You better not go getting yourself killed!"
msgstr ""
"Tch! Non fare l'eroe, amico.\n"
"Vedi di non farti ammazzare!"

msgctxt "672"
msgid "Player"
msgstr "Giocatore"

msgctxt "676"
msgid "Takasugi"
msgstr "Takasugi"
