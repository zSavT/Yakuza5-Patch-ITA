msgctxt "76"
msgid "(I should take these guys down so I don't get outflanked.)"
msgstr "(Dovrei sistemare questi tizi, così non mi farò aggirare.)"

msgctxt "88"
msgid ""
"(I should take these guys down so I don't get outflanked. That heavy "
"equipment might help.)"
msgstr ""
"(Dovrei sistemare questi tipi per evitare di farmi accerchiare. "
"Quell'attrezzatura pesante potrebbe aiutarmi.)"

msgctxt "620"
msgid "Player"
msgstr "Giocatore"
