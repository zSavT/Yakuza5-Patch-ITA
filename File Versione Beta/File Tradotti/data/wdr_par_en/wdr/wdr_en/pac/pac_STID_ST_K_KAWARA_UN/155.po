msgctxt "124"
msgid "You did it, Uncle Kaz!"
msgstr "Ce l'hai fatta, zio Kaz!"

msgctxt "148"
msgid "Aw. Well that's okay..."
msgstr "Oh. Be', non importa..."

msgctxt "172"
msgid ""
"Uncle Kaz! Catch a <Color:8>ghost koi<Color:Default>! I need to know if it's"
" really supernatural!"
msgstr ""
"Zio Kaz! Pesca una <Color:8>carpa fantasma<Color:Default>! Devo sapere se è "
"davvero soprannaturale!"
