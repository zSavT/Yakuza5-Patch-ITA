msgid "Man's Man"
msgstr "Uomo vero"

msgctxt "528"
msgid "Self-respecting Man"
msgstr "Uomo che si rispetta"

msgctxt "100_Man's Man"
msgid "You're no man if ya don't go for it now. C'mon, man up! Be a man!"
msgstr "Non sei un uomo se non ti butti adesso. Dai, fatti uomo! Sii un uomo!"

msgctxt "112_Man's Man"
msgid "No, I'm gonna pass. Let's go back to the hotel."
msgstr "No, passo. Torniamo in albergo."
