msgctxt "2556"
msgid "Player"
msgstr "Giocatore"

msgctxt "2560"
msgid "dummy"
msgstr "dummy"

msgctxt "2564"
msgid "Kinei Taxi"
msgstr "Kinei Taxi"

msgctxt "60_Player"
msgid "(First, I need to get to Uno-san!)"
msgstr "(Prima, devo andare da Uno-san!)"

msgctxt "96_Player"
msgid "(I can't afford the fare. Better scrounge up 480 yen...)"
msgstr "(Non ho i soldi per la corsa. Meglio che racimoli 480 yen...)"

msgctxt "108_Kinei Taxi"
msgid "The base fare is 480 yen. Where to?"
msgstr "La tariffa base è di 480 yen. Dove andiamo?"

msgctxt "144_Kinei Taxi"
msgid "Very well, sir."
msgstr "Molto bene, signore."

msgctxt "228_Kinei Taxi"
msgid ""
"I'm afraid you don't have enough money, sir. Please come again when you do."
msgstr ""
"Mi dispiace, signore, ma non ha abbastanza contanti. La prego di tornare "
"quando li avrà."

msgctxt "240_Kinei Taxi"
msgid "Please come again soon."
msgstr "Alla prossima!"

msgctxt "276_Kinei Taxi"
msgid "Another city? Of course, sir."
msgstr "Un'altra città? Certo, signore."
