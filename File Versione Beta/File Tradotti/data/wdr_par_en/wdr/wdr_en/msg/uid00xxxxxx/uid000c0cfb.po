msgctxt "520"
msgid "Insatiable Woman"
msgstr "Donna Insaziabile"

msgctxt "524"
msgid "Gluttonous Woman"
msgstr "Ghiottona"

msgctxt "72_Insatiable Woman"
msgid "That was delicious! Where are we going next?"
msgstr "Che bontà! Dov'è la prossima tappa?"

msgctxt "84_Insatiable Woman"
msgid ""
"We did okonomiyaki, kushikatsu... Oh! We need to do takoyaki! We still have "
"a lot of Osaka to eat through."
msgstr ""
"Abbiamo fatto okonomiyaki, kushikatsu... Oh! Dobbiamo fare i takoyaki! "
"Abbiamo ancora un sacco di Osaka da mangiare."
