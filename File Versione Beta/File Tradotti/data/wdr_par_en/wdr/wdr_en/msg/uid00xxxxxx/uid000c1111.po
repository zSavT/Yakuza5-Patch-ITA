msgctxt "476"
msgid "Satisfied Man"
msgstr "Uomo Soddisfatto"

msgctxt "480"
msgid "Unsatisfied Woman"
msgstr "Donna insoddisfatta"

msgctxt "72_Satisfied Man"
msgid "Karaoke was fun. We should get going, though."
msgstr "Il karaoke è stato divertente. Dovremmo filare, però."

msgctxt "84_Satisfied Man"
msgid ""
"I'm not done singing! I forgot to sing \"So Much More!\" Oh, I could go for "
"hours."
msgstr ""
"Non ho mica finito di cantare! Mi sono dimenticato di cantare \"So Much "
"More!\" Ah, potrei andare avanti per ore, io."
