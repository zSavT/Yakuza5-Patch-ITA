msgctxt "644"
msgid "Impatient Woman"
msgstr "Donna impaziente"

msgctxt "648"
msgid "Determined Woman"
msgstr "Donna Determinata"

msgctxt "652"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "60_Impatient Woman"
msgid "Can't you decide yet? I'm starvin'!"
msgstr "Non hai ancora deciso? Sto morendo di fame!"

msgctxt "72_Impatient Woman"
msgid ""
"Hold on! I'm searchin' review sites for places that are rated highly but "
"aren't too expensive. Just hold your horses."
msgstr ""
"Aspetta! Sto cercando sui siti di recensioni posti con buone recensioni ma "
"che non costino troppo. Frena un attimo."

msgctxt "84_Impatient Woman"
msgid "Look, even a burger will do now!"
msgstr "Senti, ormai mi va bene pure un hamburger!"
