msgctxt "592"
msgid "Wistful Man"
msgstr "Uomo malinconico"

msgctxt "596"
msgid "World-weary Man"
msgstr "Uomo stanco del mondo"

msgctxt "60_Wistful Man"
msgid ""
"I want to leave everything behind and go off to Okinawa. That's paradise!"
msgstr "Voglio mollare tutto e andarmene a Okinawa. È il paradiso!"

msgctxt "72_Wistful Man"
msgid "Sounds good. I'll book time off this summer."
msgstr "Ottimo. Mi prendo le ferie quest'estate."

msgctxt "84_Wistful Man"
msgid "What are you sayin'? I'm going this weekend."
msgstr "Che stai a dire? Ci vado questo weekend."
