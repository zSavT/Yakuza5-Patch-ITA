msgctxt "44_Employee"
msgid "Hello, sir. You may purchase chips here."
msgstr "Salve, signore. Può acquistare fiches qui."

msgctxt "56_Employee"
msgid "Would you like to buy some chips?"
msgstr "Vorrebbe comprare delle fiches?"

msgctxt "80_Employee"
msgid "Excellent. I'll get your chips ready."
msgstr "Ottimo. Ti preparo subito le fiches."

msgctxt "92_Employee"
msgid "Here are your 50 chips. Thank you."
msgstr "Ecco le tue 50 fiches. Grazie."

msgctxt "128_Employee"
msgid "Excellent. I'll get your chips ready."
msgstr "Ottimo. Ti preparo subito le fiches."

msgctxt "140_Employee"
msgid "Here are your 100 chips. Thank you."
msgstr "Ecco le tue 100 fiches. Grazie."

msgctxt "176_Employee"
msgid "Excellent. I'll get your chips ready."
msgstr "Ottimo. Ti preparo subito le fiches."

msgctxt "188_Employee"
msgid "Here are your 500 chips. Thank you."
msgstr "Ecco le tue 500 fiches. Grazie."

msgctxt "224_Employee"
msgid "Excellent. I'll get your chips ready."
msgstr "Ottimo. Ti preparo subito le fiches."

msgctxt "236_Employee"
msgid "Here are your 1,000 chips. Thank you."
msgstr "Ecco a te le tue 1.000 fiches. Grazie."

msgctxt "272_Employee"
msgid "Excellent. I'll get your chips ready."
msgstr "Ottimo. Ti preparo subito le fiches."

msgctxt "284_Employee"
msgid "Here are your 10,000 chips. Thank you."
msgstr "Ecco le tue 10.000 fiches. Grazie."

msgctxt "308_Employee"
msgid "I'm afraid you don't have enough money, sir."
msgstr "Mi dispiace, signore, ma non ha abbastanza soldi."

msgctxt "320_Employee"
msgid "Please come again."
msgstr "Torni pure a trovarci."
