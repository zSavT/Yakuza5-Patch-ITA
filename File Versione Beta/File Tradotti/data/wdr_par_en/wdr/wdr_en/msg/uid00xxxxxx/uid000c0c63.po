msgctxt "612"
msgid "Haruka"
msgstr "Haruka"

msgctxt "616"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "132_Haruka"
msgid ""
"We live at the Café Portugal building over on Nagasu Boulevard. Mom and dad "
"should be working there right now."
msgstr ""
"Viviamo all'edificio del Café Portugal, su Nagasu Boulevard. Mamma e papà "
"dovrebbero essere lì a lavorare proprio adesso."

msgctxt "144_Kiryu"
msgid "Portugal, huh? All right. I'll bring your dad over right away."
msgstr "Café Portugal, eh? D'accordo. Vado subito a prendere tuo padre."
