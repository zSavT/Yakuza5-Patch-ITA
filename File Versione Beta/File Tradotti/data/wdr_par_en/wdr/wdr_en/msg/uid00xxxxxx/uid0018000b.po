msgctxt "376"
msgid "Infatuated Fifty-Year-Old"
msgstr "Cinquantenne Infatuato"

msgctxt "72_Infatuated Fifty-Year-Old"
msgid ""
"There's a club on Nagasu Boulevard called La Seine. There's a girl there "
"named Riku-chan. She's dynamite. Ba-ba-boom!"
msgstr ""
"C'è un club su Nagasu Boulevard che si chiama La Seine. C'è una ragazza lì "
"che si chiama Riku-chan. È una bomba. Che schianto!"
