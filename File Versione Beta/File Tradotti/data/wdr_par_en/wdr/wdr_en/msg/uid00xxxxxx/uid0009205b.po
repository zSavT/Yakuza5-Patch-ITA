msgctxt "980"
msgid "Devil Killers Member"
msgstr "Membro dei Devil Killers"

msgctxt "984"
msgid "Talk_Odosu"
msgstr "Talk_Odosu"

msgctxt "60_Devil Killers Member"
msgid ""
"Hey, gramps, hand over your money! I'm with the Devil Killers, so don't go "
"gettin' any big ideas about fightin' back."
msgstr ""
"Ehi, vecchiaccio, sgancia i soldi! Sono dei Devil Killers, quindi non farti "
"strane idee di reagire."

msgctxt "72_Devil Killers Member"
msgid "You listenin'!? Fork over the money, ya old fuck!"
msgstr "Stai a sentire!? Sgancia i soldi, vecchio stronzo!"

msgctxt "96_Devil Killers Member"
msgid "Seriously!? Fuck this."
msgstr "Sul serio!? Fanculo!"
