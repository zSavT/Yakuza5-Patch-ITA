msgctxt "572"
msgid "Carnivorous Girl"
msgstr "Ragazza carnivora"

msgctxt "576"
msgid "Crabby Boy"
msgstr "Ragazzo Granchio"

msgctxt "72_Carnivorous Girl"
msgid ""
"You just gotta have lamb barbeque when you're in Hokkaido. That's, like, "
"their signature dish."
msgstr ""
"Devi proprio mangiare l'agnello alla brace quando sei a Hokkaido. È, tipo, "
"il loro piatto forte."

msgctxt "84_Carnivorous Girl"
msgid "No, no, no! Crab! We're having crab tonight!"
msgstr "No, no, no! Granchio! Stasera si mangia granchio!"
