msgctxt "332"
msgid "Tourist"
msgstr "Turista"

msgctxt "72_Tourist"
msgid ""
"Man, I thought Fukuoka was in the sunny south, but it's just as cold as "
"everywhere else."
msgstr ""
"Mamma mia, pensavo che Fukuoka fosse nel sud assolato, ma fa freddo come "
"dappertutto."
