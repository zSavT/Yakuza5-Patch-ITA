msgctxt "324"
msgid "Drunkard"
msgstr "Ubriaco"

msgctxt "60_Drunkard"
msgid ""
"Urp! *hic* Had a couple too many drinks. The doctor says I shouldn't, but "
"fuggem."
msgstr ""
"Urp! *hic* Ho alzato un po' troppo il gomito. Il dottore dice che non "
"dovrei, ma fanculo."
