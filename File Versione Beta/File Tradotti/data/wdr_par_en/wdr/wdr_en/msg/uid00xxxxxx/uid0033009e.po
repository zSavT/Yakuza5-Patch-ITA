msgctxt "1864"
msgid "Player"
msgstr "Giocatore"

msgctxt "1868"
msgid "Taxi"
msgstr "Taxi"

msgctxt "1872"
msgid "dummy"
msgstr "dummy"

msgctxt "56_Player"
msgid "(I can't afford the fare. Better scrounge up 550 yen...)"
msgstr "(Non ho i soldi per la corsa. Devo racimolare 550 yen...)"

msgctxt "68_Taxi"
msgid "The base fare is 550 yen. Where are you headed?"
msgstr "La tariffa base è di 550 yen. Dove desidera andare?"

msgctxt "104_Taxi"
msgid ""
"I'm afraid you don't have enough money, sir. Please come again when you do."
msgstr ""
"Mi dispiace, signore, ma non ha abbastanza contanti. La prego di tornare "
"quando li avrà."

msgctxt "116_Taxi"
msgid "Very well, sir."
msgstr "Molto bene, signore."

msgctxt "176_Taxi"
msgid "Please come again soon."
msgstr "Arrivederci a presto."

msgctxt "188_Taxi"
msgid "Another city? Of course, sir."
msgstr "Un'altra città? Certo, signore."
