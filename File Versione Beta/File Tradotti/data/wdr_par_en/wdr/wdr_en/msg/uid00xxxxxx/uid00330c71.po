msgctxt "60_店員"
msgid ""
"お客様、７７７タウン．ｎｅｔ "
"（スリーセブンタウンドットネット） "
"はご存知ですか？"
msgstr ""
"お客様、７７７タウン．ｎｅｔ "
"（スリーセブンタウンドットネット） "
"はご存知ですか？"

msgctxt "72_店員"
msgid ""
"パソコンで２４時間パチスロ・パチンコが "
"いつでも遊び放題のオンラインゲームです。"
msgstr ""
"パソコンで２４時間パチスロ・パチンコが "
"いつでも遊び放題のオンラインゲームです。"

msgctxt "84_店員"
msgid ""
"往年の名機種から最新機種まで３０メーカー・ "
"２００機種以上のパチスロ・パチンコが "
"遊べます。"
msgstr ""
"往年の名機種から最新機種まで３０メーカー・ "
"２００機種以上のパチスロ・パチンコが "
"遊べます。"

msgctxt "96_Talk_Yes"
msgid ""
"今だけ、７７７タウン．ｎｅｔ "
"（スリーセブンタウンドットネット） "
"で限定アイテムがＧＥＴできる……"
msgstr ""
"今だけ、７７７タウン．ｎｅｔ "
"（スリーセブンタウンドットネット） "
"で限定アイテムがＧＥＴできる……"

msgctxt "108_店員"
msgid ""
"パスワードをお教えしますので、 "
"是非一度お試しください。"
msgstr ""
"パスワードをお教えしますので、 "
"是非一度お試しください。"

msgctxt "120_店員"
msgid "パスワードは「<Color:7>こめぞー<Color:Default>」です。"
msgstr "パスワードは「<Color:7>こめぞー<Color:Default>」です。"
