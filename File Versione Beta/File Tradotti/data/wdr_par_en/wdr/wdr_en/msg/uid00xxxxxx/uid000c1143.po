msgctxt "508"
msgid "Guilt-ridden Man"
msgstr "Uomo roso dai sensi di colpa"

msgctxt "512"
msgid "Seething Woman"
msgstr "Donna Furente"

msgctxt "72_Guilt-ridden Man"
msgid ""
"I'm telling you, you're blowing this out of proportion. I only went to eat "
"with Akemi. There's nothing going on between us!"
msgstr ""
"Ma ti dico, stai esagerando. Sono andato a mangiare solo con Akemi. Non c'è "
"niente tra di noi!"

msgctxt "84_Guilt-ridden Man"
msgid "Look me in the eyes and say that."
msgstr "Guardami dritto negli occhi e dillo."
