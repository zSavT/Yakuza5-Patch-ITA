msgctxt "92_Talk_Kamae"
msgid ""
"もう、無理や…… "
"俺は完璧に自信をなくしてもうた……"
msgstr ""
"もう、無理や…… "
"俺は完璧に自信をなくしてもうた……"

msgctxt "104_たしなめる女"
msgid ""
"めげないでください!! "
"めげたらそこで連載が終了なんです！"
msgstr ""
"めげないでください!! "
"めげたらそこで連載が終了なんです！"

msgctxt "116_桐生"
msgid "……すまんが、ちょっとどいてくれないか？"
msgstr "……すまんが、ちょっとどいてくれないか？"

msgctxt "140_Talk_Kamae"
msgid "あ、すみません。"
msgstr "あ、すみません。"

msgctxt "152_ごねる男"
msgid "あ！　桐生さんやないですか！"
msgstr "あ！　桐生さんやないですか！"

msgctxt "164_桐生"
msgid "ん？　誰だ？"
msgstr "ん？　誰だ？"

msgctxt "176_南沢"
msgid ""
"え、ええ～…… "
"俺ですやん、一年前、相方が面倒かけた "
"「火星ファイター」の南沢ですやん！"
msgstr ""
"え、ええ～…… "
"俺ですやん、一年前、相方が面倒かけた "
"「火星ファイター」の南沢ですやん！"

msgctxt "188_桐生"
msgid "ああ、お前、また神室町に来てたのか。"
msgstr "ああ、お前、また神室町に来てたのか。"

msgctxt "200_桐生"
msgid ""
"……あと、去年 "
"面倒をかけたのは相方じゃなくて、お前の方だ。"
msgstr ""
"……あと、去年 "
"面倒をかけたのは相方じゃなくて、お前の方だ。"

msgctxt "212_南沢"
msgid ""
"あぁ……　このブレが一切ない正論ツッコミ…… "
"相変わらず切れ味バツグンやな……"
msgstr ""
"あぁ……　このブレが一切ない正論ツッコミ…… "
"相変わらず切れ味バツグンやな……"

msgctxt "224_南沢"
msgid ""
"いやぁ、しかしまた桐生さんにお会いできて、 "
"メッチャ感動ですわ。"
msgstr ""
"いやぁ、しかしまた桐生さんにお会いできて、 "
"メッチャ感動ですわ。"

msgctxt "236_たしなめる女"
msgid "お知り合いですか？"
msgstr "お知り合いですか？"

msgctxt "248_南沢"
msgid ""
"知り合いなんてもんやない！ "
"桐生さんといえば "
"幻の「３人目の火星ファイター」として有名やで。"
msgstr ""
"知り合いなんてもんやない！ "
"桐生さんといえば "
"幻の「３人目の火星ファイター」として有名やで。"

msgctxt "260_桐生"
msgid "……メンバーになった覚えはないぞ。"
msgstr "……メンバーになった覚えはないぞ。"

msgctxt "272_南沢"
msgid ""
"そや！　桐生さん！ "
"俺を助けると思うて、女の子の落とし方、 "
"教えたってください!!"
msgstr ""
"そや！　桐生さん！ "
"俺を助けると思うて、女の子の落とし方、 "
"教えたってください!!"

msgctxt "284_桐生"
msgid "話が見えないが……"
msgstr "話が見えないが……"

msgctxt "296_浅井"
msgid ""
"あ、えと、申し遅れました。私、 "
"TVBros.という雑誌の編集をしております、 "
"浅井と申します。"
msgstr ""
"あ、えと、申し遅れました。私、 "
"TVBros.という雑誌の編集をしております、 "
"浅井と申します。"

msgctxt "308_浅井"
msgid ""
"今、「火星ファイター南沢のキャバクラ攻略」 "
"っていう連載企画の取材で来てるんですが……"
msgstr ""
"今、「火星ファイター南沢のキャバクラ攻略」 "
"っていう連載企画の取材で来てるんですが……"

msgctxt "320_浅井"
msgid ""
"南沢さん、キャバ嬢と全然仲良くなれなくて…… "
"すごく困ってたんです。"
msgstr ""
"南沢さん、キャバ嬢と全然仲良くなれなくて…… "
"すごく困ってたんです。"

msgctxt "332_南沢"
msgid ""
"だ、だって……火星ファイターやぞー、 "
"南沢やぞー、言うても、 "
"誰もキャーキャーしてくれへんし……"
msgstr ""
"だ、だって……火星ファイターやぞー、 "
"南沢やぞー、言うても、 "
"誰もキャーキャーしてくれへんし……"

msgctxt "344_浅井"
msgid ""
"南沢さん、自分でこの企画持ち込んで来たくせに。 "
"まさかこんな体たらくとは…… "
"責任、とってもらわなくちゃねぇ……"
msgstr ""
"南沢さん、自分でこの企画持ち込んで来たくせに。 "
"まさかこんな体たらくとは…… "
"責任、とってもらわなくちゃねぇ……"

msgctxt "380_Talk_Kamae"
msgid ""
"桐生さん！　お願いします!! "
"「ＳＨＩＮＥ」と「ＪＵＷＥＬ」ってキャバクラの "
"女の子のこと……教えてください！"
msgstr ""
"桐生さん！　お願いします!! "
"「ＳＨＩＮＥ」と「ＪＵＷＥＬ」ってキャバクラの "
"女の子のこと……教えてください！"

msgctxt "392_南沢"
msgid ""
"このままやと、ホンマに恥っさらしな "
"記事を載せられてしまうんです……!!"
msgstr "このままやと、ホンマに恥っさらしな記事を載せられてしまうんです……!!"

msgctxt "404_桐生"
msgid ""
"神室町のキャバクラの攻略、か…… "
"最近会ったキャバ嬢のことだけでよければ "
"教えてやれるが……"
msgstr ""
"神室町のキャバクラの攻略、か…… "
"最近会ったキャバ嬢のことだけでよければ "
"教えてやれるが……"

msgctxt "416_南沢"
msgid "あ、ありがとうございます！"
msgstr "あ、ありがとうございます！"

msgctxt "428_南沢"
msgid ""
"俺ら、「Ｃｕｅｚ　ＢＡＲ」って店に "
"大抵おるんで。 "
"お時間あるときにでも、顔出したってください!!"
msgstr ""
"俺ら、「Ｃｕｅｚ　ＢＡＲ」って店に "
"大抵おるんで。 "
"お時間あるときにでも、顔出したってください!!"

msgctxt "452_Talk_Kamae"
msgid "浅井さんも！　ほら！　頭下げて!!"
msgstr "浅井さんも！　ほら！　頭下げて!!"

msgctxt "464_浅井"
msgid ""
"何でアンタがえらそうに…… "
"お願いします！　雑誌の誌面がかかってるんです!!"
msgstr ""
"何でアンタがえらそうに…… "
"お願いします！　雑誌の誌面がかかってるんです!!"

msgctxt "476_桐生"
msgid ""
"わかった。 "
"情報が集まったら「Ｃｕｅｚ　ＢＡＲ」に "
"顔を出そう。"
msgstr ""
"わかった。 "
"情報が集まったら「Ｃｕｅｚ　ＢＡＲ」に "
"顔を出そう。"

msgctxt "488_南沢"
msgid "よろしくお願いしまっす！"
msgstr "よろしくお願いしまっす！"
