msgctxt "44_スーツの男"
msgid "あ、桐生さん。いつぞやはどうも。"
msgstr "あ、桐生さん。いつぞやはどうも。"

msgctxt "56_桐生"
msgid "その格好、就職活動中なのか。"
msgstr "その格好、就職活動中なのか。"

msgctxt "68_スーツの男"
msgid ""
"はい。でも面接がどうも苦手で…… "
"さっき50社目の会社からお祈りメールが届きました……"
msgstr ""
"はい。でも面接がどうも苦手で…… "
"さっき50社目の会社からお祈りメールが届きました……"

msgctxt "80_スーツの男"
msgid ""
"そうだ！ 桐生さん。 "
"僕の面接の練習相手になってくださいよ！"
msgstr ""
"そうだ！ 桐生さん。 "
"僕の面接の練習相手になってくださいよ！"

msgctxt "104_スーツの男"
msgid ""
"ありがとうございます。 "
"桐生さんには面接官の役をお願いします。 "
"僕に何か質問してみてください。"
msgstr ""
"ありがとうございます。 "
"桐生さんには面接官の役をお願いします。 "
"僕に何か質問してみてください。"

