msgid "Never mind."
msgstr "Non importa."

msgctxt "44_Employee"
msgid "Hello, sir. What can I do for you today?"
msgstr "Buongiorno, signore. Cosa posso fare per lei oggi?"

msgctxt "56_Employee"
msgid "Certainly. What would you like to buy?"
msgstr "Certo. Cosa desidera acquistare?"

msgctxt "80_Employee"
msgid "Thank you very much."
msgstr "Grazie mille."

msgctxt "92_Employee"
msgid "Of course. What would you like to sell?"
msgstr "Certo. Cosa vorrebbe vendere?"

msgctxt "116_Employee"
msgid "Thank you very much."
msgstr "Grazie mille."
