msgctxt "56_Haruka"
msgid "Aw. What a shame. Well, give it another shot!"
msgstr "Ah, che peccato. Su, riprovaci!"

msgctxt "68_Haruka"
msgid ""
"Maybe you should try using a <Color:8>Catnip Stick<Color:Default> or a "
"<Color:8>Tuna Burger Set<Color:Default>?"
