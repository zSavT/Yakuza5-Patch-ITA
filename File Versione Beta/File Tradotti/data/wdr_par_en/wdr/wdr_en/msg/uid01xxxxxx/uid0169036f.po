msgctxt "1060"
msgid "Haruka"
msgstr "Haruka"

msgctxt "1064"
msgid "Go to the Event Hall"
msgstr "Vai alla Sala Eventi"

msgctxt "1068"
msgid "Get Ready First"
msgstr "Preparati prima"

msgctxt "44_Haruka"
msgid ""
"(Let's see. This is the event hall where the Dance Battle "
"Summit is being held.)"
msgstr ""
"(Vediamo. Questa è la sala eventi dove si tiene il Dance Battle "
"Summit.)"

msgctxt "56_Haruka"
msgid ""
"(There isn't much time before the summit starts. What should "
"I do?)"
msgstr ""
"(Non manca molto all'inizio del summit. Cosa dovrei "
"fare?)"

msgctxt "68_Haruka"
msgid "(I'd better make sure I'm prepared for the summit.)"
msgstr "(Sarà meglio che mi assicuri di essere pronta per il summit.)"

msgctxt "80_Haruka"
msgid ""
"(I'd better go to the event hall. I wonder if Akari is there "
"yet?)"
msgstr ""
"(Sarà meglio andare alla sala eventi. Chissà se Akari è "
"già lì.)"
