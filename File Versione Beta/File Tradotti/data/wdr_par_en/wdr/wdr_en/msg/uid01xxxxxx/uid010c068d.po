msgctxt "44_Kiryu"
msgid "I'm from Nagasu Taxi. Sorry for the wait."
msgstr "Sono della Nagasu Taxi. Mi scusi per l'attesa."

msgctxt "56_Laid-back Man"
msgid ""
"To <Color:22>Meisei Street<Color:Default> please. There's no hurry, so drive"
" carefully, won't you?"
msgstr ""
"A <Color:22>Meisei Street<Color:Default>, per favore. Non c'è fretta, quindi"
" vada piano, mi raccomando."

msgctxt "68_Kiryu"
msgid "Of course. Let's go."
msgstr "Certo. Andiamo."
