msgctxt "19380"
msgid "You should be all right if you bathe regularly."
msgstr "Se si lava regolarmente non dovrebbero esserci problemi."

msgctxt "19384"
msgid "You should give her a good scolding."
msgstr "Dovrebbe darle una bella strigliata."

msgctxt "19388"
msgid "All girls are like that in their teens."
msgstr "Le adolescenti sono tutte così."

msgctxt "19392"
