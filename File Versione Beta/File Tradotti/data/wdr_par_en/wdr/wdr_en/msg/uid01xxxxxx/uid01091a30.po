msgctxt "464"
msgid "Saejima"
msgstr "Saejima"

msgctxt "468"
msgid "Okudera"
msgstr "Okudera"

msgctxt "44_Saejima"
msgid "He's right up ahead. Hasn't moved for a while."
msgstr "È proprio lì davanti. Non si muove da un pezzo."

msgctxt "56_Okudera"
msgid "He's staying still? That means he could be in his den."
msgstr "Sta fermo? Il che significa che potrebbe essere nel suo covo."

msgctxt "68_Okudera"
msgid "Let's hurry."
msgstr "Sbrighiamoci."
