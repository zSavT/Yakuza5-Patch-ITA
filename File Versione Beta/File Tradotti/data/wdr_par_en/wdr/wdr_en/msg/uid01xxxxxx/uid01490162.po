msgctxt "556"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "560"
msgid "Go Inside"
msgstr "Entra"

msgctxt "564"
msgid "Stay Put"
msgstr "Rimani dove sei"

msgctxt "44_Akiyama"
msgid ""
"(He hasn't come out yet. Should I go in and see how he's "
"doing?)"
msgstr ""
"(Non è ancora uscito. Dovrei entrare e vedere come se la "
"cava?)"

msgctxt "56_Akiyama"
msgid "(I'll just wait and see.)"
msgstr "(Mi limito ad aspettare e vedere.)"
