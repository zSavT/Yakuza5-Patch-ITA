msgctxt "44_Saejima"
msgid "Now we gotta split up. I'll leave Baba in your hands, Shinada!"
msgstr "Adesso ci dividiamo. Lascio Baba nelle tue mani, Shinada!"

msgctxt "56_Shinada"
msgid "You can count on me! You be careful, Saejima-san!"
msgstr "Puoi contare su di me! Stai attento, Saejima-san!"
