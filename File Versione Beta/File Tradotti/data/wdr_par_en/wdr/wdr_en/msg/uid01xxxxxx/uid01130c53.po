msgctxt "1068"
msgid "Ultimate Move: Dragon Spirit"
msgstr "Mossa Finale: Dragon Spirit"

msgctxt "120_Ultimate Move: Dragon Spirit"
msgid ""
" "
"<Color:7>Dragon Spirit<Color:Default> Tutorial "
" "
"In this battle, you can only damage Sosuke "
"using <Color:7>Dragon Spirit<Color:Default>."
msgstr ""
"<Color:7>Dragon Spirit<Color:Default> Tutorial "
" "
"In questo scontro, puoi danneggiare Sosuke "
"solo usando <Color:7>Dragon Spirit<Color:Default>."

msgctxt "132_Ultimate Move: Dragon Spirit"
msgid ""
" "
"Press <Action:Battle_Extreme_Heat@Combat> in Heat Mode to activate "
"<Color:7>Dragon Spirit<Color:Default>. "
" "
"Try attacking Sosuke after pressing <Action:Battle_Extreme_Heat@Combat> to "
"trigger <Color:7>Dragon Spirit<Color:Default>."
msgstr ""
"Premi <Action:Battle_Extreme_Heat@Combat> in modalità Furore per attivare "
"<Color:7>Dragon Spirit<Color:Default>. "
" "
"Prova ad attaccare Sosuke dopo aver premuto <Action:Battle_Extreme_Heat@Combat> per "
"attivare <Color:7>Dragon Spirit<Color:Default>."
