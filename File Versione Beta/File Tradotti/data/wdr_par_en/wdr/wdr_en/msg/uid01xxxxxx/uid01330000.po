msgid "Kiryu"
msgstr "Kiryu"

msgctxt "1380"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "1384"
msgid "Saejima"
msgstr "Saejima"

msgctxt "1388"
msgid "Shinada"
msgstr "Shinada"

msgctxt "1392"
msgid "Haruka"
msgstr "Haruka"

msgctxt "132_Kiryu"
msgid "(I don't need anything here right now.)"
msgstr "(Non c'è niente che mi serva qui, al momento.)"

msgctxt "144_Akiyama"
msgid ""
"(Eh, I don't need to be here right now. Maybe I'll stop by another time.)"
msgstr ""
"(Eh, non ho motivo di stare qui adesso. Magari ripasserò un'altra volta.)"

msgctxt "156_Saejima"
msgid ""
"(Nothin' here I need. Might drop by for a drink when things blow over.)"
msgstr ""
"(Non c'è niente per me qui. Magari farò un salto a bere qualcosa quando "
"si saranno calmate le acque.)"

msgctxt "168_Shinada"
msgid "(New Serena... Looks way too hoity-toity for my taste!)"
msgstr "(New Serena... Sembra un posto un po' troppo fighetto per i miei gusti!)"

msgctxt "180_Haruka"
msgid ""
"(So many happy memories in this place... I'd give anything to come here and "
"just have a nice time with Uncle Kaz again.)"
msgstr ""
"(Quanti bei ricordi in questo posto... Darei qualsiasi cosa per poter tornare "
"qui e passare di nuovo dei bei momenti con lo zio Kaz.)"
