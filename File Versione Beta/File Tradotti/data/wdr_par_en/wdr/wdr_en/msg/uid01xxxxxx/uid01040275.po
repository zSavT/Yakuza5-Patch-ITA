msgctxt "1448"
msgid "Tutorial"
msgstr "Tutorial"

msgctxt "1452"
msgid "Announcement"
msgstr "Annuncio"

msgctxt "124_Tutorial"
msgid ""
"Adjust the spin by pressing the "
"<Action:Button_DPad_Left@Bowling><Action:Button_DPad_Right@Bowling> buttons "
"before releasing the ball."
msgstr ""
"Regola l'effetto premendo i pulsanti "
"<Action:Button_DPad_Left@Bowling><Action:Button_DPad_Right@Bowling> prima di"
" rilasciare la palla."

msgctxt "136_Tutorial"
msgid "Press <Action:Button_Cross@Bowling> to adjust throwing power."
msgstr ""
"Premi <Action:Button_Cross@Bowling> per regolare la potenza di lancio."

msgctxt "148_Tutorial"
msgid "Press <Action:Button_Cross@Bowling> to determine the direction."
msgstr "Premi <Action:Button_Cross@Bowling> per determinare la direzione."

msgctxt "160_Tutorial"
msgid ""
"When selecting a ball, use "
"<Action:Button_DPad_Left@Bowling><Action:Button_DPad_Right@Bowling> to "
"choose where to stand, then confirm with <Action:Button_Cross@Bowling>."
msgstr ""
"Quando selezioni una palla, usa "
"<Action:Button_DPad_Left@Bowling><Action:Button_DPad_Right@Bowling> per "
"scegliere dove posizionarti, poi conferma con <Action:Button_Cross@Bowling>."

msgctxt "172_Tutorial"
msgid ""
"Select a ball by using "
"<Action:Button_DPad_Up@Bowling><Action:Button_DPad_Down@Bowling> buttons."
msgstr ""
"Seleziona una palla usando i pulsanti "
"<Action:Button_DPad_Up@Bowling><Action:Button_DPad_Down@Bowling>."

msgctxt "184_Announcement"
msgid ""
"Attention all bowlers! It's time for Midnight Madness! You only get one "
"chance! Bowl a strike and you'll get a prize!"
msgstr ""
"Attenzione a tutti i lanciatori! È ora di Midnight Madness! Avete solo una "
"possibilità! Fate uno strike e vincerete un premio!"
