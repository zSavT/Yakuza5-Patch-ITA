msgid "Player"
msgstr "Giocatore"

msgctxt "1808"
msgid "Play"
msgstr "Gioca"

msgctxt "1812"
msgid "Don't Play"
msgstr "Non giocare"

msgctxt "1816"
msgid "dummy"
msgstr "dummy"

msgctxt "44_Player"
msgid "(It's Beast King slot machine number 34. Should I give it a try?)"
msgstr "(È la slot machine Bestia Re numero 34. Ci faccio un tentativo?)"

msgctxt "56_Player"
msgid "(No, let's not.)"
msgstr "(No, lasciamo perdere.)"

msgctxt "92_Player"
msgid "(I'm too broke to play. I need at least 1,000 yen.)"
msgstr "(Sono troppo al verde per giocare. Mi servono almeno 1.000 yen.)"

msgctxt "200_Player"
msgid "(Sure. Why not?)"
msgstr "(Certo, perché no?)"
