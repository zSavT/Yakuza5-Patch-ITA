msgctxt "572"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "92_Player"
msgid "(I don't need to be here right now.)"
msgstr "(Non dovrei proprio essere qui, adesso.)"

msgctxt "104_Akiyama"
msgid ""
"(The bartender isn't here. He said to meet him in "
"Shofukucho's parking lot.)"
msgstr ""
"(Il barista non c'è. Mi ha detto di incontrarlo nel "
"parcheggio di Shofukucho.)"

msgctxt "116_Akiyama"
msgid "(I should just see what happens for now.)"
msgstr "(Dovrei solo vedere che succede, per adesso.)"
