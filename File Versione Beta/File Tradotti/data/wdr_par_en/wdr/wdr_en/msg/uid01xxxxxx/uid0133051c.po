msgctxt "2368"
msgid "Player"
msgstr "Giocatore"

msgctxt "2372"
msgid "Start Fishing"
msgstr "Inizia a pescare"

msgctxt "2376"
msgid "Not Now"
msgstr "Non ora"

msgctxt "2380"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "120_Player"
msgid ""
"(Coach Igarashi told me to go and fish something up. Looks like there's a "
"good fishing spot over there.)"
msgstr ""
"(Il coach Igarashi mi ha detto di andare a pescare qualcosa. Sembra esserci "
"un buon punto per pescare laggiù.)"

msgctxt "132_Player"
msgid ""
"(It looks like I could fish here. Maybe I'll drop a line in for a bit.)"
msgstr "(Sembra che potrei pescare qui. Magari lancio la lenza per un po'.)"

msgctxt "156_Player"
msgid "(Okay, let's give it a go!)"
msgstr "(Ok, dai, proviamoci!)"

msgctxt "180_Player"
msgid "(I don't have any bait to use.)"
msgstr "(Non ho esche da usare.)"

msgctxt "192_Player"
msgid "(I guess I'll come back later.)"
msgstr "(Forse è meglio se torno più tardi.)"

msgctxt "204_Player"
msgid ""
"(Come to think of it, the coach wanted me to do some fishing. Now isn't the "
"time, though.)"
msgstr ""
"(A pensarci bene, il coach voleva che pescassi. Ma non è questo il momento.)"

msgctxt "216_Player"
msgid ""
"(It looks like I could fish here. Maybe I'll drop a line in for a bit.)"
msgstr "(Sembra che potrei pescare qui. Magari lancio la lenza per un po'.)"

msgctxt "240_Player"
msgid "(Okay, let's give it a try.)"
msgstr "(Ok, facciamo un tentativo.)"

msgctxt "264_Player"
msgid "(I don't have anything to use for bait.)"
msgstr "(Non ho niente da usare come esca.)"

msgctxt "276_Player"
msgid "(Maybe some other time.)"
msgstr "(Magari un'altra volta.)"
