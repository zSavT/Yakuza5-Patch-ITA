msgctxt "56_Player"
msgid ""
"(Tch, there's a cop. Better cross the road and take the long way around.)"
msgstr ""
"Tsk, c'è uno sbirro. Meglio attraversare la strada e fare il giro lungo."

msgctxt "80_Player"
msgid "(Huh?)"
msgstr "(Eh?)"

msgctxt "104_Player"
msgid "(There's a cop on that side, too!)"
msgstr "(C'è uno sbirro pure da quella parte!)"

msgctxt "116_Player"
msgid "(Gotta hide! Wait... Huh?)"
msgstr "(Devo nascondermi! Aspetta... Eh?)"

msgctxt "152_Player"
msgid "(Ain't nowhere to hide, so I need a disguise!)"
msgstr "(Non c'è un buco dove nascondersi, quindi mi serve un travestimento!)"
