msgctxt "452_Kiryu"
msgid "I see."
msgstr "Capisco."

msgctxt "464_Fancily Dressed Woman"
msgid ""
"(Wow, it's almost as if she believes this is all true. I'll ask one more "
"thing.)"
msgstr ""
"(Caspita, sembra crederci per davvero. Le farò un'altra domanda.)"

msgctxt "476_Fancily Dressed Woman"
msgid "Where is the Kingdom of Coutand?"
msgstr "Dov'è il Regno di Coutand?"

msgctxt "488_Maybe a Princess"
