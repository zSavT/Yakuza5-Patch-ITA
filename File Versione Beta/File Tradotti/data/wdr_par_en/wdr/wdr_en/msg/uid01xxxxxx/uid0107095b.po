msgctxt "3016"
msgid "Freelancer Masa"
msgstr "Freelancer Masa"

msgctxt "380_Freelancer Masa"
msgid "First, we pick the banker."
msgstr "Per prima cosa, si sceglie il banco."

msgctxt "392_Freelancer Masa"
msgid "I'm the banker!"
msgstr "Faccio io il banco!"

msgctxt "404_Freelancer Masa"
msgid "How much you wanna risk?"
msgstr "Quanto vuoi puntare?"

msgctxt "416_Freelancer Masa"
msgid "All right, here goes!"
msgstr "Allora, si parte!"

msgctxt "428_Freelancer Masa"
msgid "Here we go, my turn!"
msgstr "Eccoci, tocca a me!"

msgctxt "440_Freelancer Masa"
msgid "(This line should not appear.)"
msgstr "(Questa riga non dovrebbe apparire.)"

msgctxt "452_Freelancer Masa"
msgid "Time to settle our bets!"
msgstr "È ora di fare i conti!"

msgctxt "464_Freelancer Masa"
msgid "You're the banker."
msgstr "Fai tu il banco."

msgctxt "476_Freelancer Masa"
msgid "Now we change the banker."
msgstr "Ora si cambia il banco."

msgctxt "488_Freelancer Masa"
msgid "One more game?"
msgstr "Ancora una partita?"

msgctxt "500_Freelancer Masa"
msgid "Damn, I'm flat-out broke! Sorry, I've had it for today."
msgstr "Maledizione, sono completamente al verde! Scusate, per oggi basta così."

msgctxt "512_Freelancer Masa"
msgid "What's wrong, maxed out? Better luck next time, buddy!"
msgstr "Che c'è, hai finito i soldi? Sarà per la prossima, amico!"

msgctxt "524_Freelancer Masa"
msgid "Banker's Bet-Settling Messages"
msgstr "Messaggi del banco per il pagamento delle scommesse"

msgctxt "536_Freelancer Masa"
msgid "A banker's roll of 1-3-5... That's a 3!"
msgstr "Il banco ha fatto 1-3-5... È un 3!"

msgctxt "548_Freelancer Masa"
msgid "A 1-3-5 roll by the first player... That's a 3!"
msgstr "Il primo giocatore ha fatto 1-3-5... È un 3!"

msgctxt "560_Freelancer Masa"
msgid "A 1-3-5 roll gets the preceding player's roll!"
msgstr "Con un 1-3-5, si copia il tiro del giocatore precedente!"

msgctxt "572_Freelancer Masa"
msgid "A banker's roll of 2-4-6... That's a 4!"
msgstr "Il banco ha fatto 2-4-6... È un 4!"

msgctxt "584_Freelancer Masa"
msgid "A 2-4-6 roll gets the next player's roll!"
msgstr "Con un 2-4-6, si copia il tiro del giocatore successivo!"

msgctxt "596_Freelancer Masa"
msgid "A 2-4-6 roll by the last player... That's a 4!"
msgstr "L'ultimo giocatore ha fatto 2-4-6... È un 4!"

msgctxt "608_Freelancer Masa"
msgid "A 2-4-6 roll gets the last player's roll!"
msgstr "Con un 2-4-6, si copia il tiro dell'ultimo giocatore!"

msgctxt "620_Freelancer Masa"
msgid "A 1-3-5 was rolled after a 2-4-6."
msgstr "È uscito un 1-3-5 dopo un 2-4-6."

msgctxt "632_Freelancer Masa"
msgid "Oh, yeah! A 6-3-4!"
msgstr "E vai! 6-3-4!"
