msgctxt "452"
msgid "Player"
msgstr "Giocatore"

msgctxt "44_Player"
msgid ""
"(Tatsuya said he was tryin' to think up a new dish for a strugglin' eatery.)"
msgstr ""
"(Tatsuya ha detto che stava cercando di tirare fuori un nuovo piatto per un "
"locale in difficoltà.)"

msgctxt "56_Player"
msgid ""
"(They said it was a <Color:7>new café<Color:Default>. Maybe I'll go look for"
" it when I have time.)"
msgstr ""
"(Hanno detto che era un <Color:7>nuovo caffè<Color:Default>. Magari andrò a "
"cercarlo quando avrò tempo.)"
