msgctxt "44"
msgid ""
"Do you want to try again? "
"If not, you can retry later by checking the "
"batting center's bulletin board."
msgstr ""
"Vuoi riprovare? "
"Se no, puoi riprovare più tardi controllando la "
"bacheca del centro di battuta."

msgctxt "536"
msgid "Try Again"
msgstr "Riprova"

msgctxt "540"
msgid "Not Now"
msgstr "Non ora"
