msgctxt "84"
msgid "You now have access to a hideout."
msgstr "Ora hai accesso a un covo."

msgctxt "204"
msgid "You now have access to a hideout."
msgstr "Ora hai accesso a un covo."

msgctxt "3552"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "3556"
msgid "Go to Bed"
msgstr "Vai a letto"

msgctxt "3560"
msgid "Not Yet"
msgstr "Non ancora"

msgctxt "96_Kiryu"
msgid ""
"Here you can save your game, move items to the Item Box, and view your play "
"stats."
msgstr ""
"Qui puoi salvare la partita, spostare gli oggetti nella Cassa Oggetti e "
"visualizzare le tue statistiche di gioco."

msgctxt "108_Kiryu"
msgid "Furthermore, your health will recover while at a hideout."
msgstr "Inoltre, la tua salute si riprenderà al covo."

msgctxt "132_Kiryu"
msgid "(Phew, another long day. Should probably get some sleep.)"
msgstr "(Uff, un'altra lunga giornata. Sarà meglio andare a dormire.)"

msgctxt "144_Kiryu"
msgid "(Actually, I think I'll look around town a bit more.)"
msgstr "(A dire il vero, credo che farò un altro giro in città.)"

msgctxt "156_Kiryu"
msgid "(Need to be fresh for tomorrow.)"
msgstr "(Devo essere carico per domani.)"

