msgctxt "44_Kiryu"
msgid "I'm from Nagasu Taxi. Sorry for the wait."
msgstr "Sono della Nagasu Taxi. Mi scusi per l'attesa."

msgctxt "56_Child"
msgid "Hey, mom. Why's the sea blue?"
msgstr "Ehi, mamma. Perché il mare è blu?"

msgctxt "68_Mother"
msgid "I'm afraid I don't know, sweetie."
msgstr "Purtroppo non lo so, tesoro."

msgctxt "80_Mother"
msgid ""
"Come on, let's get in the taxi. Could you take us to <Color:22>Meisei "
"Street<Color:Default> please?"
msgstr ""
"Dai, saliamo in taxi. Ci potrebbe portare a <Color:22>Meisei "
"Street<Color:Default>, per favore?"

msgctxt "92_Kiryu"
msgid "Of course. Let's go."
msgstr "Certo. Andiamo."
