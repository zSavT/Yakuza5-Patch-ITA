msgctxt "792"
msgid "Haruka"
msgstr "Haruka"

msgctxt "60_Haruka"
msgid ""
"(Another person who wants to have a dance battle? I wonder "
"who it is this time.)"
msgstr ""
"(Un'altra persona che vuole fare una sfida di ballo? Mi chiedo "
"chi sia questa volta.)"

msgctxt "72_Haruka"
msgid ""
"(She's supposed to be waiting in the South Shofukucho "
"parking lot. I'll go check it out.)"
msgstr ""
"(Dovrebbe star aspettando al South Shofukucho. Parcheggio. Andrò a "
"controllare.)"

msgctxt "96_Haruka"
msgid "(An email. I wonder who it's from.)"
msgstr "(Un'email. Mi chiedo da chi provenga.)"
