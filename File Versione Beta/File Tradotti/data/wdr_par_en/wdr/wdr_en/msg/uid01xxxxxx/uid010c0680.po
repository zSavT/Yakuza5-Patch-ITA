msgctxt "44_Kiryu"
msgid "Sorry for the wait. I'm here from Nagasu Taxi."
msgstr "Mi scusi per l'attesa. Sono di Nagasu Taxi."

msgctxt "56_Lady"
msgid ""
"Oh, no worries. I'd like to go to <Color:22>Ose Bridge<Color:Default>, "
"please!"
msgstr ""
"Oh, nessun problema. Vorrei andare a <Color:22>Ose Bridge<Color:Default>, "
"per favore!"

msgctxt "68_Kiryu"
msgid "(She's quite attractive. But...)"
msgstr "È piuttosto attraente. Però..."

msgctxt "116_Kiryu"
msgid "(She has a huge nose hair sticking out!)"
msgstr "(Ha un enorme pelo del naso che le spunta fuori!)"

msgctxt "128_Nose Hair Lady"
msgid "Hm? Is something wrong?"
msgstr "Hm? C'è qualcosa che non va?"

msgctxt "140_Kiryu"
msgid ""
"Oh, no. I was just nosing- <Italic>noticing</Italic> something. Please, get "
"in."
msgstr ""
"Oh, no. Stavo solo ficcando il naso – intendevo <Italic>notando</Italic> "
"qualcosa. Prego, s'accomodi."
