msgctxt "44_Player"
msgid ""
"(This is CR Virtua Fighter MVJC pachinko machine number 7. Maybe I should "
"give it a try.)"
msgstr ""
"(Questa è la macchina pachinko CR Virtua Fighter MVJC numero 7. Magari ci "
"faccio un giro.)"

msgctxt "56_Player"
msgid "(No, let's not.)"
msgstr "(No, meglio di no.)"

msgctxt "92_Player"
msgid "(I'm too broke to play. I need at least 1,000 yen.)"
msgstr "(Sono troppo al verde per giocare. Mi servono almeno 1.000 yen.)"

msgctxt "200_Player"
msgid "(Sure. Why not?)"
msgstr "(Ma sì. Perché no?)"
