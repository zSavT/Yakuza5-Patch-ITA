msgctxt "496"
msgid "Passenger"
msgstr "Passeggero"

msgctxt "500"
msgid "No Longer Laid-back Man"
msgstr "Uomo non più rilassato"

msgctxt "76_Passenger"
msgid "What wonderful driving! I can really rest easy riding with you!"
msgstr ""
"Che guida eccezionale! Posso stare davvero tranquillo a viaggiare con te!"

msgctxt "88_Passenger"
msgid "You drive quite well."
msgstr "Lei guida proprio bene."

msgctxt "100_No Longer Laid-back Man"
msgid "I wish you'd drive a little more carefully."
msgstr "Vorrei che guidasse con un po' più di attenzione."
