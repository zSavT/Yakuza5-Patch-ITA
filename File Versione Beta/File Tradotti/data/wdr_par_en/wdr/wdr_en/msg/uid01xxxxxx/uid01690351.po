msgid "Haruka"
msgstr "Haruka"

msgctxt "60_Haruka"
msgid ""
"(I wonder if Akari will come? Anyway, I'd better head to the "
"event hall southeast of Iwao Bridge.)"
msgstr ""
"(Chissà se Akari verrà? Comunque, faccio meglio ad andare alla "
"sala eventi a sud-est del Ponte Iwao.)"

msgctxt "84_Haruka"
msgid "(An email. I wonder who it's from.)"
msgstr "(Un'email. Chissà da chi arriva.)"
