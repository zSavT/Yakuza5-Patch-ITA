msgid "Kiryu"
msgstr "Kiryu"

msgctxt "92_Kiryu"
msgid "(Everyone's busy. I don't have to go now.)"
msgstr "(Sono tutti impegnati. Non devo andare adesso.)"

msgctxt "104_Kiryu"
msgid "(I'm with Haruka. I don't have to go now.)"
msgstr "(Sono con Haruka. Non devo andare adesso.)"

msgctxt "116_Kiryu"
msgid "(I'm done with work for the day. I should get home.)"
msgstr "(Ho finito il lavoro per oggi. Dovrei tornare a casa.)"
