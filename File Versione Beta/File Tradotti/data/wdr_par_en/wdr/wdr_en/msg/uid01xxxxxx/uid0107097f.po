msgctxt "44"
msgid ""
"Adjusting Shot Angle "
"First, choose the angle to strike the cue ball."
msgstr ""
"Regolazione dell'Angolo di Tiro "
"Innanzitutto, scegli l'angolo per colpire la bilia battente."

msgctxt "56"
msgid ""
"Use "
"<Action:Button_LS_Up@Billard><Action:Button_LS_Down@Billard><Action:Button_LS_Left@Billard><Action:Button_LS_Right@Billard>"
" to adjust the angle."
msgstr ""
"Usa "
"<Action:Button_LS_Up@Billard><Action:Button_LS_Down@Billard><Action:Button_LS_Left@Billard><Action:Button_LS_Right@Billard>"
" per regolare l'angolo."
