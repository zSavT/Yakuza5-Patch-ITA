msgctxt "684"
msgid "Charge Attack"
msgstr "Attacco caricato"

msgctxt "44_Charge Attack"
msgid ""
"Saejima can unleash a powerful charge attack "
"by <Color:7>holding down<Color:Default> <Action:Battle_Heavy_Attack@Combat>. "
" "
"It can be done at the end of combos by <Color:7>holding down<Color:Default> "
"<Action:Battle_Heavy_Attack@Combat> after moves like <Action:Battle_Normal_Attack@Combat><Action:Battle_Heavy_Attack@Combat> or <Action:Battle_Normal_Attack@Combat><Action:Battle_Normal_Attack@Combat><Action:Battle_Heavy_Attack@Combat>."
msgstr ""
"Saejima può scatenare un potente attacco caricato "
"<Color:7>tenendo premuto<Color:Default> <Action:Battle_Heavy_Attack@Combat>. "
" "
"Può essere eseguito alla fine delle combo <Color:7>tenendo premuto<Color:Default> "
"<Action:Battle_Heavy_Attack@Combat> dopo mosse come <Action:Battle_Normal_Attack@Combat><Action:Battle_Heavy_Attack@Combat> o <Action:Battle_Normal_Attack@Combat><Action:Battle_Normal_Attack@Combat><Action:Battle_Heavy_Attack@Combat>."
