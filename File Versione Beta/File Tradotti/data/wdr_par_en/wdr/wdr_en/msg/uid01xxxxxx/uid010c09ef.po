msgctxt "1016"
msgid "Player"
msgstr "Giocatore"

msgctxt "76_Player"
msgid "(It's... kind of shady. I don't think I should go in.)"
msgstr "(È... un po' losco. Non mi pare il caso di entrare.)"

msgctxt "88_Player"
msgid ""
"(It's a business of some sort. I should keep my ears open in town and get "
"more information.)"
msgstr ""
"(È un'attività di qualche tipo. Dovrei tenere le orecchie aperte in città e "
"raccogliere più informazioni.)"

msgctxt "112_Player"
msgid "(I should come here alone.)"
msgstr "(Dovrei venire qui da solo.)"
