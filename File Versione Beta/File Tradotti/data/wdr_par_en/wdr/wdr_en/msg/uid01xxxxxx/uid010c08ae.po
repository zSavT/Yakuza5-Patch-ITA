msgctxt "44_Kiryu"
msgid "I'm from Nagasu Taxi. Sorry for the wait."
msgstr "Sono della Nagasu Taxi. Mi scusi per l'attesa."

msgctxt "56_Female Passenger"
msgid ""
"Let me in! I need you to take me to a client, and fast! I'll navigate while "
"you drive!"
msgstr ""
"Mi faccia salire! Devo andare da un cliente, e subito! Le indico io la "
"strada mentre guida!"

msgctxt "68_Kiryu"
msgid "(Looks like she's in a hurry.)"
msgstr "(Sembra che sia di fretta.)"

msgctxt "80_Kiryu"
msgid "Understood. Let's go."
msgstr "Capito. Andiamo."
