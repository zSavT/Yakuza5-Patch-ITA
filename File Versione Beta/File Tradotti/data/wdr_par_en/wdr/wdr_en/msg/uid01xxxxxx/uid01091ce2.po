msgid "Saejima"
msgstr "Saejima"

msgctxt "156_Saejima"
msgid "(There! Should be the last one.)"
msgstr "(Eccolo! Dovrebbe essere l'ultimo.)"

msgctxt "180_Saejima"
msgid "(Gunfire. Was that Narumi?)"
msgstr "(Colpi di arma da fuoco. Era quello Narumi?)"

msgctxt "192_Saejima"
msgid "(I hafta stop him. Need to catch up, even with this rough terrain...)"
msgstr ""
"(Devo fermarlo. Devo raggiungerlo, anche con questo terreno accidentato...)"
