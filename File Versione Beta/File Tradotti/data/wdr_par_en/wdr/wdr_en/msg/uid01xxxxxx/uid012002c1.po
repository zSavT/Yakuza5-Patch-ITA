msgctxt "932"
msgid "Laid-back Man"
msgstr "Uomo Rilassato"

msgctxt "936"
msgid "○Driving safely."
msgstr "○Guida sicura."

msgctxt "940"
msgid "△Getting to the destination fast."
msgstr "△Guida veloce."

msgctxt "944"
msgid "□Providing a thrilling experience."
msgstr "□Esperienza da brivido."

msgctxt "948"
msgid "Slightly Nervous Man"
msgstr "Uomo Leggermente Nervoso"

msgctxt "44_Laid-back Man"
msgid "What do you focus on while working?"
msgstr "Su cosa ti concentri mentre lavori?"

msgctxt "68_Laid-back Man"
msgid "That's good to hear."
msgstr "Sono contento di sentirlo."

msgctxt "80_Laid-back Man"
msgid "I see."
msgstr "Capisco."

msgctxt "92_Laid-back Man"
msgid "What!? You're scaring me."
msgstr "Ma cosa!? Mi stai spaventando."

msgctxt "104_Laid-back Man"
msgid "Fine. Ignore me, then."
msgstr "Va bene. Ignorami, allora."
