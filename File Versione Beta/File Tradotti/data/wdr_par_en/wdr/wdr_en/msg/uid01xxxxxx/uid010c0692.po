msgctxt "44_Kiryu"
msgid "I'm from Nagasu Taxi. Sorry for the wait."
msgstr "Sono della Nagasu Taxi. Scusi l'attesa."

msgctxt "56_Man in a Hurry"
msgid ""
"<Color:22>Fukuhaku Street<Color:Default>, please. I'm in a bit of a rush, "
"but you should make it there in time driving normally, so no need to go "
"crazy fast."
msgstr ""
"<Color:22>Fukuhaku Street<Color:Default>, per favore. Ho un po' di fretta, "
"ma ce la dovresti fare in tempo guidando normalmente, quindi non c'è bisogno"
" di andare come un pazzo."

msgctxt "68_Kiryu"
msgid "Understood. Let's go."
msgstr "Capito. Andiamo."
