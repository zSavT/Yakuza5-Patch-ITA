msgid "Saejima"
msgstr "Saejima"

msgctxt "44_Saejima"
msgid "(These footprints are a lot bigger than any man's.)"
msgstr "(Queste impronte sono un bel po' più grandi di quelle di un uomo.)"

msgctxt "56_Saejima"
msgid "(That talk of the abominable snowman... Could it be true?)"
msgstr ""
"(Quelle storie sull'abominevole uomo delle nevi... Potrebbe essere vero?)"
