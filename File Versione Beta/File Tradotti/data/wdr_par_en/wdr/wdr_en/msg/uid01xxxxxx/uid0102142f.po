msgctxt "772"
msgid "Haruka"
msgstr "Haruka"

msgctxt "776"
msgid "Sleep Until Evening"
msgstr "Dormi Fino a Sera"

msgctxt "780"
msgid "Don't Sleep"
msgstr "Non Dormire"

msgctxt "44_Haruka"
msgid ""
"(Horie-san said he'd be back from the station in the "
"evening. Maybe I should try to sleep.)"
msgstr ""
"(Horie-san ha detto che sarebbe rientrato dalla stazione in "
"serata. Forse dovrei provare a dormire.)"

msgctxt "56_Haruka"
msgid "(No, I'd rather be doing something.)"
msgstr "(No, preferirei fare qualcosa.)"

msgctxt "68_Haruka"
msgid "(I think I'll try to get some sleep.)"
msgstr "(Penso che proverò a dormire un po'.)"
