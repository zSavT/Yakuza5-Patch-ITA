msgid "You cannot go beyond this point in the Demo."
msgstr "Non puoi andare oltre questo punto nella Demo."

msgctxt "588"
msgid "Haruka"
msgstr "Haruka"

msgctxt "76_Haruka"
msgid "(I shouldn't go very far.)"
msgstr "Non dovrei allontanarmi troppo."

msgctxt "100_Haruka"
msgid ""
"(I'm supposed to be out shopping with Yui-chan. I wonder if she's finished "
"with that yet. I should ask.)"
msgstr ""
"(Dovrei essere fuori a fare shopping con Yui-chan. Mi chiedo se abbia già "
"finito con quello. Dovrei chiederglielo.)"
