msgctxt "972"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "68_Kiryu"
msgid ""
"(Guess they ditched their car and took cover inside that building. Now I've "
"got them.)"
msgstr ""
"(Immagino che abbiano mollato la macchina e si siano rifugiati in "
"quell'edificio. Ora li ho beccati.)"

msgctxt "80_Kiryu"
msgid "(This is the building. Hang on, Riku. I'm coming for you!)"
msgstr "(Questo è l'edificio. Tieni duro, Riku. Sto arrivando a prenderti!)"
