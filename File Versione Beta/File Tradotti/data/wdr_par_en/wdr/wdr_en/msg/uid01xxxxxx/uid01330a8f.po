msgctxt "136_Haruka"
msgid "(What should I do?)"
msgstr "(Che faccio?)"

msgctxt "148_Haruka"
msgid "(My pay should be deposited.)"
msgstr "(Dovrebbero avermi accreditato la paga.)"

msgctxt "160_Haruka"
msgid "(Huh!?)"
msgstr "(Cosa!?)"

msgctxt "172_Haruka"
msgid "(Oh, that's right. I withdrew it all. I'd better earn some more.)"
msgstr "(Ah, giusto. Ho prelevato tutto. Farò meglio a guadagnare ancora un po'.)"

msgctxt "184_Haruka"
msgid "(No, let's not do this now.)"
msgstr "(No, non facciamolo ora.)"

msgctxt "196_Haruka"
msgid ""
"(I have to send money to Morning Glory. I wonder how everyone's doing.) "
"　 "
msgstr ""
"(Devo mandare dei soldi all'Orfanotrofio Morning Glory. Chissà come stanno "
"tutti.)"

msgctxt "220_Haruka"
msgid "(Maybe later.)"
msgstr "(Magari più tardi.)"

msgctxt "232_Haruka"
msgid ""
"(I'm sure this isn't enough. I have to work hard and send more money next time) "
"　 "
msgstr ""
"(Sono sicura che non basteranno. Devo impegnarmi e mandare più "
"soldi la prossima volta.)"

msgctxt "244_Haruka"
msgid "(There we go!)"
msgstr "(Ecco fatto!)"

