msgctxt "552"
msgid "Ultimate Move: Tiger Puppetry"
msgstr "Mossa Suprema: Burattinaio della Tigre"

msgctxt "44_Ultimate Move: Tiger Puppetry"
msgid ""
"Saejima can <Color:7>grab an enemy by the legs<Color:Default> "
"and swing them around like a weapon. "
" "
"[Grabbing an Enemy's Legs] "
"Press <Action:Battle_Drop_Weapon@Combat> near a fallen enemy's legs to grab them, "
"then use <Action:Battle_Normal_Attack@Combat> or <Action:Battle_Heavy_Attack@Combat> to swing them around."
msgstr ""
"Saejima può <Color:7>afferrare un nemico per le gambe<Color:Default> "
"e farlo roteare come un'arma. "
" "
"[Afferrare le Gambe di un Nemico] "
"Premi <Action:Battle_Drop_Weapon@Combat> vicino alle gambe di un nemico a terra per afferrarle, "
"poi usa <Action:Battle_Normal_Attack@Combat> o <Action:Battle_Heavy_Attack@Combat> per farlo roteare."
