msgctxt "56_Saejima"
msgid "(The transmitter showed he was 'round here.)"
msgstr "(Il trasmettitore mostrava che era qui intorno.)"

msgctxt "68_Saejima"
msgid ""
"(Yama-oroshi's gotta show his face sometime. Just gotta lie low n' wait.)"
msgstr ""
"(Yama-oroshi deve pur farsi vedere prima o poi. Devo solo starmene nascosto "
"e aspettare.)"

msgctxt "200_Saejima"
msgid "(Showtime...)"
msgstr "(È ora di far sul serio...)"

msgctxt "224_Saejima"
msgid "(We finish this now, Yama-oroshi.)"
msgstr "(La facciamo finita adesso, Yama-oroshi.)"

msgctxt "236_Saejima"
msgid "(Here goes!)"
msgstr "(Ci siamo!)"
