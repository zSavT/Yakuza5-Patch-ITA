msgctxt "1056"
msgid "Kurosaki"
msgstr "Kurosaki"

msgctxt "140_Shirakawa"
msgid "Can't touch this, Shinada!"
msgstr "Non mi sfiori nemmeno, Shinada!"

msgctxt "152_Takamine"
msgid "No hard feelings, but you're about to get smoked!"
msgstr "Senza rancore, ma stai per essere asfaltato!"

msgctxt "164_Michio"
msgid "My whole life depends on this! Here goes!"
msgstr "Ne va della mia intera vita! Ci siamo!"

msgctxt "188_Asada"
msgid "Gonna write a sexy article about this one?"
msgstr "Ci scriverai un articolo piccante su 'sta faccenda?"

msgctxt "200_Kurosaki"
msgid "I'm not losing to the likes of you! Get ready!"
msgstr "Non ho intenzione di perdere contro uno come te! Fatti sotto!"

msgctxt "212_Shirakawa"
msgid "Get ready, Shinada! We're settling the score, once and for all!"
msgstr "Preparati, Shinada! Regoliamo i conti, una volta per tutte!"
