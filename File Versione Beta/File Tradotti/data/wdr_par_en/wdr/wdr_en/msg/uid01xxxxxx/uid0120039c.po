msgctxt "136_Haruka"
msgid ""
"You're incredible, Uncle Kaz! You look so cool watching the dice! You've got"
" eagle eyes!"
msgstr ""
"Sei incredibile, Zio Kaz! Hai un'aria così figa mentre guardi i dadi! Hai "
"gli occhi d'aquila!"

msgctxt "160_Haruka"
msgid "Aw. Too bad. Well, better luck next time."
msgstr "Ah. Peccato. Beh, la prossima andrà meglio."

msgctxt "184_Haruka"
msgid ""
"Uncle Kaz! Try to <Color:8>get 1,000 points or more at cee-"
"lo<Color:Default>!"
msgstr ""
"Zio Kaz! Cerca di <Color:8>fare 1.000 punti o più al cee-lo<Color:Default>!"

msgctxt "196_Kiryu"
msgid ""
"(Haruka wants me to <Color:8>get 1,000 points or more at cee-"
"lo<Color:Default>.)"
msgstr ""
"(Haruka vuole che io <Color:8>faccia 1.000 punti o più al cee-"
"lo<Color:Default>.)"
