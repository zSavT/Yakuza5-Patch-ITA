msgctxt "784"
msgid "Player"
msgstr "Giocatore"

msgctxt "108_Player"
msgid "(I came here already. Let's go somewhere else.)"
msgstr "(Sono già passato di qui. Andiamo da un'altra parte.)"

msgctxt "132_Player"
msgid "(Sekai no Yamachan, huh? I could tell Tatsuya about this place.)"
msgstr "(Sekai no Yamachan, eh? Potrei dire a Tatsuya di questo posto.)"

msgctxt "156_Player"
msgid "(I wish I could stop by, but the batting center awaits.)"
msgstr "(Vorrei farci un salto, ma il centro battuta mi aspetta.)"
