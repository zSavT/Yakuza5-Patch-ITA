msgctxt "1140"
msgid "Ultimate Move: Launch Strike"
msgstr "Mossa Suprema: Colpo di Lancio"

msgctxt "120_Ultimate Move: Launch Strike"
msgid ""
"<Color:7>Launch Strike<Color:Default> Tutorial "
" "
"In this battle, you can only deal damage to Saigo with the "
"<Color:7>Launch Strike<Color:Default> move."
msgstr ""
"<Color:7>Colpo di Lancio<Color:Default> Tutorial "
" "
"In questa battaglia, puoi solo infliggere danni a Saigo con la mossa "
"<Color:7>Colpo di Lancio<Color:Default>."

msgctxt "132_Ultimate Move: Launch Strike"
msgid ""
"While in Heat Mode, you can launch your opponent into the "
"air with <Action:Battle_Heavy_Attack@Combat> to activate <Color:7>Launch Strike<Color:Default>. "
" "
"Try for a combo attack by rapidly tapping <Action:Battle_Normal_Attack@Combat> after launching "
"your opponent with <Action:Battle_Heavy_Attack@Combat>."
msgstr ""
"Mentre sei in modalità Furore, puoi lanciare il tuo avversario in "
"aria con <Action:Battle_Heavy_Attack@Combat> per attivare <Color:7>Colpo di Lancio<Color:Default>. "
" "
"Prova una combo premendo rapidamente <Action:Battle_Normal_Attack@Combat> dopo aver lanciato "
"il tuo avversario con <Action:Battle_Heavy_Attack@Combat>."
