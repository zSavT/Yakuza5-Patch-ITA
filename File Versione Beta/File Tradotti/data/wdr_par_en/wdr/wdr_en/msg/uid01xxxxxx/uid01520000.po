msgctxt "124"
msgid ""
"ようこそ。ただいまから、 "
"ブラックジャックのチュートリアルを開始します。 "
"3戦ほどお付き合いください。"
msgstr ""
"ようこそ。ただいまから、 "
"ブラックジャックのチュートリアルを開始します。 "
"3戦ほどお付き合いください。"

msgctxt "136"
msgid ""
"ブラックジャックは配られたカードの合計を "
"できるだけ21に近づけるゲームです。"
msgstr ""
"ブラックジャックは配られたカードの合計を "
"できるだけ21に近づけるゲームです。"

msgctxt "148"
msgid ""
"合計数値が22以上になるとBURSTとなり、 "
"無条件で負けとなってしまうので "
"気を気をつけて下さい。"
msgstr ""
"合計数値が22以上になるとBURSTとなり、 "
"無条件で負けとなってしまうので "
"気を気をつけて下さい。"

msgctxt "160"
msgid ""
"TOTALという数値が、 "
"今のあなたの手札の合計値です。"
msgstr ""
"TOTALという数値が、 "
"今のあなたの手札の合計値です。"

msgctxt "172"
msgid ""
"合計値が11以下のとき、 "
"BURSTすることはあり得ません。 "
"カードを引く選択を選んでみましょう。"
msgstr ""
"合計値が11以下のとき、 "
"BURSTすることはあり得ません。 "
"カードを引く選択を選んでみましょう。"

msgctxt "184"
msgid ""
"これ以上カードをもらうと "
"21を超えてしまいそうだと感じたら "
"STANDしましょう。"
msgstr ""
"これ以上カードをもらうと "
"21を超えてしまいそうだと感じたら "
"STANDしましょう。"

msgctxt "196"
msgid "HITを選択すると、1枚カードを引きます。"
msgstr "HITを選択すると、1枚カードを引きます。"

msgctxt "208"
msgid ""
"DOUBLEDOWNも1枚カードをひきますが "
"引いた後の数字が必ず勝負しなければなりません。 "
"BET額を2倍にできます。"
msgstr ""
"DOUBLEDOWNも1枚カードをひきますが "
"引いた後の数字が必ず勝負しなければなりません。 "
"BET額を2倍にできます。"
