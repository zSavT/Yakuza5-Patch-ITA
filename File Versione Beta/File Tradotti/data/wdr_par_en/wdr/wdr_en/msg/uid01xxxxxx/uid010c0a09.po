msgctxt "2836"
msgid "Player"
msgstr "Giocatore"

msgctxt "2840"
msgid "To Street Level"
msgstr "Al livello della strada"

msgctxt "2844"
msgid "To the Third Floor"
msgstr "Al terzo piano"

msgctxt "2848"
msgid "Never Mind"
msgstr "Lascia perdere"

msgctxt "2852"
msgid "Haruka"
msgstr "Haruka"

msgctxt "2856"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "108_Player"
msgid "(Where should I take the elevator?)"
msgstr "(Dove devo andare con l'ascensore?)"

msgctxt "132_Haruka"
msgid "I can't go out dressed like this. I should get changed."
msgstr "Non posso uscire vestita così. Dovrei cambiarmi."

msgctxt "168_Player"
msgid "(Never mind.)"
msgstr "(Lascia perdere.)"

msgctxt "180_Haruka"
msgid "Akiyama-san, aren't we going to Park-san's office?"
msgstr "Akiyama-san, non andiamo all'ufficio di Park-san?"

msgctxt "192_Akiyama"
msgid "Whoops, right you are."
msgstr "Ops, hai ragione."

msgctxt "204_Haruka"
msgid "Akiyama-san, aren't we going up to the roof?"
msgstr "Akiyama-san, non andiamo sul tetto?"

msgctxt "216_Akiyama"
msgid "Oh, yeah. Let's go."
msgstr "Ah, sì. Andiamo."

msgctxt "228_Akiyama"
msgid ""
"(The girl who last saw Park-san is supposed to be in the "
"lesson studio.)"
msgstr ""
"(La ragazza che ha visto Park-san per ultima dovrebbe essere nella "
"sala prove.)"

