msgctxt "548"
msgid "Player"
msgstr "Giocatore"

msgctxt "44_Player"
msgid "(Tatsuya said he's trying to think up a dish for a struggling eatery.)"
msgstr ""
"(Tatsuya ha detto che sta cercando di ideare un piatto per un locale in "
"difficoltà.)"

msgctxt "56_Player"
msgid ""
"(It was a <Color:7>new café<Color:Default> or something. I should check it "
"out. I know there's no such thing as a free lunch, but hey, I can still "
"hope!)"
msgstr ""
"(Era un <Color:7>nuovo caffè<Color:Default> o qualcosa del genere. Dovrei "
"darci un'occhiata. So che non c'è pranzo gratis, ma ehi, posso sempre "
"sperare!)"
