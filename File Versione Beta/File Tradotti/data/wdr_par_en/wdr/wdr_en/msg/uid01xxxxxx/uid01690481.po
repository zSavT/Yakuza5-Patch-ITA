msgctxt "108"
msgid "You withdrew all of your pay."
msgstr "Hai ritirato tutti i tuoi guadagni."

msgctxt "1196"
msgid "Haruka"
msgstr "Haruka"

msgctxt "1200"
msgid "Withdraw Money"
msgstr "Prelievo Denaro"

msgctxt "1204"
msgid "Quit"
msgstr "Esci"

msgctxt "1208"
msgid "dummy"
msgstr "dummy"

msgctxt "60_Haruka"
msgid "(My pay should have come in by now.)"
msgstr "(I miei guadagni dovrebbero essere arrivati ormai.)"

msgctxt "72_Haruka"
msgid "(What!?)"
msgstr "(Che!?)"

msgctxt "84_Haruka"
msgid "(Oh, that's right. I withdrew it all. I'd better earn some more.)"
msgstr ""
"(Ah, è vero. L'ho ritirato tutto. È meglio che guadagni ancora un po'.)"

msgctxt "96_Haruka"
msgid "(My pay should have come in by now.)"
msgstr "(I miei guadagni dovrebbero essere arrivati ormai.)"

msgctxt "120_Haruka"
msgid "(I worked hard for this money, so I should be careful with it.)"
msgstr "(Ho sgobbato per questi soldi, quindi devo andarci cauta.)"

msgctxt "132_Haruka"
msgid "(No, let's not do this now.)"
msgstr "(No, non facciamolo adesso.)"
