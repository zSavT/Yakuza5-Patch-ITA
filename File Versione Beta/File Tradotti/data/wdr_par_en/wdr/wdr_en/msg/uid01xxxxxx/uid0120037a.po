msgctxt "136_Haruka"
msgid "You're incredible, Uncle Kaz! You really hit it big!"
msgstr "Sei incredibile, Zio Kaz! Hai fatto il botto!"

msgctxt "160_Haruka"
msgid "Darn. What a shame, huh, Uncle Kaz?"
msgstr "Mannaggia. Che peccato, eh, Zio Kaz?"

msgctxt "184_Haruka"
msgid ""
"Uncle Kaz! How's your poker face? Can you <Color:8>get 2,000 or more chips "
"playing poker<Color:Default>?"
msgstr ""
"Zio Kaz! Com'è la tua faccia da poker? Riesci a <Color:8>ottenere 2.000 o "
"più fiches giocando a poker<Color:Default>?"

msgctxt "196_Kiryu"
msgid ""
"(Haruka wants me to <Color:8>get 2,000 or more chips in "
"poker<Color:Default>.)"
msgstr ""
"(Haruka vuole che io <Color:8>ottenga 2.000 o più fiches giocando a "
"poker<Color:Default>.)"
