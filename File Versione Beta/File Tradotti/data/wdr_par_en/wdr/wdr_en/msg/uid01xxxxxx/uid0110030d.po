msgctxt "1428"
msgid "Saejima"
msgstr "Saejima"

msgctxt "156_Saejima"
msgid "Whoa there. Don't try no half-assed tricks on me."
msgstr "Ehi, frena. Non provare a farmi trucchi da quattro soldi."

msgctxt "168_Saejima"
msgid "Whoa there. You ain't tryin' to cheat, are ya?"
msgstr "Ehi, frena. Non starai mica barando, eh?"

msgctxt "180_Saejima"
msgid "Heh, whatever."
msgstr "Eh, vabbè."

msgctxt "192_Saejima"
msgid "......"
msgstr "......"

msgctxt "204_Saejima"
msgid "(Huh? She ain't even fazed. Was I wrong?)"
msgstr "(Eh? Non fa nemmeno una piega. Mi sbagliavo?)"

msgctxt "216_Saejima"
msgid "(Haruka's sayin' it'll be even. Hmm... What to do...)"
msgstr "(Haruka sta dicendo che uscirà pari. Mmm... Che faccio...)"

msgctxt "228_Saejima"
msgid "(Haruka's sayin' it'll be odd. Hmm... What to do...)"
msgstr "(Haruka sta dicendo che uscirà dispari. Mmm... Che faccio...)"

msgctxt "240_Saejima"
msgid "(Burned through my points.)"
msgstr "(Ho bruciato i miei punti.)"

msgctxt "252_Saejima"
msgid "(The item don't seem to work no more.)"
msgstr "(L'oggetto non sembra funzionare più.)"
