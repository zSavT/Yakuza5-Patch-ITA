msgstr "SS1_M_NML_TAX_sigh"

msgctxt "12220"
msgid "You beat some sense into them."
msgstr "Li rimetta in riga a suon di sberle."

msgctxt "12224"
msgid "You cater to their tastes."
msgstr "Assecondi i loro gusti."

msgctxt "12228"
msgid "You should be listening to them."
msgstr "Dovrebbe iniziare ad ascoltarli."

msgctxt "12232"
msgid "SS1_P_TAX_question"
msgstr "SS1_P_TAX_question"

msgctxt "12236"
msgid "I don't take tips like that."
msgstr "Non accetto mance del genere."

msgctxt "12240"
msgid "That depends on how big the tip is."
msgstr "Dipende da quanto è grossa la mancia."

msgctxt "12244"
msgid "I'll take the tip, but my vote can't be bought."
msgstr "Accetto la mancia, ma il mio voto non si compra."

msgctxt "12248"
msgid "SS1_P_TAX_idle_hearing"
msgstr "SS1_P_TAX_idle_hearing"

