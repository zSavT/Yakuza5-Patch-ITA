msgctxt "2076"
msgid "Yui"
msgstr "Yui"

msgctxt "2080"
msgid "Akari"
msgstr "Akari"

msgctxt "2084"
msgid "Haruka"
msgstr "Haruka"

msgctxt "68_Yui"
msgid "Well, should we go home, then?"
msgstr "Beh, torniamo a casa, allora?"

msgctxt "80_Akari"
msgid "I guess... Wait a minute! I have an idea."
msgstr "Mmmh... Aspetta un attimo! Ho un'idea."

msgctxt "92_Akari"
msgid ""
"Seeing how we're all together, why don't we go to a "
"PrintCircle?"
msgstr ""
"Dato che siamo tutte qui, perché non andiamo a un "
"PrintCircle?"

msgctxt "104_Haruka"
msgid "PrintCircle?"
msgstr "PrintCircle?"

msgctxt "116_Yui"
msgid ""
"Great idea! I haven't done that in a while. What do you say, "
"Haruka-chan?"
msgstr ""
"Bella idea! È un po' che non lo faccio. Che ne dici, "
"Haruka-chan?"

msgctxt "140_Yui"
msgid "Okay!"
msgstr "Ok!"
