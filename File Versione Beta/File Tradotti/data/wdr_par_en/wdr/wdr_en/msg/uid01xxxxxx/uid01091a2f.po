msgctxt "44_Saejima"
msgid "We're gettin' close."
msgstr "Ci siamo quasi."

msgctxt "56_Saejima"
msgid "He's still movin' away from us, but we're closin' the gap for sure."
msgstr ""
"Si sta ancora allontanando da noi, ma stiamo recuperando terreno di sicuro."

msgctxt "68_Okudera"
msgid "Good, let's keep up the chase."
msgstr "Bene, continuiamo l'inseguimento."
