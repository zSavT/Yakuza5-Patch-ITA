msgctxt "235\t903848\t0\tSUS"
msgid ""
msgstr ""

msgctxt "235\t903849\t1\tCHK"
msgid "Saejima-san!"
msgstr "Saejima-san!"

msgctxt "235\t903862\t2\tCHK"
msgid "Let's do this, Shinada!"
msgstr "Facciamolo, Shinada!"

msgctxt "235\t903886\t3\tCHK"
msgid "Can't believe this many came."
msgstr "Non riesco a credere che siano venuti in così tanti."

msgctxt "235\t903916\t4\tCHK"
msgid "Let me go! Stop it!"
msgstr "Lasciami andare! Smettila!"

msgctxt "235\t903936\t5\tCHK"
msgid "Come on, we've been going out a while now."
msgstr "Andiamo, è da un po' che usciamo insieme ormai."

msgctxt "235\t903979\t6\tCHK"
msgid "It's about time we took this up a notch!"
msgstr "È ora di fare un passo avanti!"

msgctxt "235\t904020\t7\tCHK"
msgid "We aren't going out! I don't even know you!"
msgstr "Non stiamo uscendo insieme! Non ti conosco nemmeno!"

msgctxt "235\t904064\t8\tCHK"
msgid "You're disgusting! Let go of me!"
msgstr "Sei disgustoso! Lasciami!"

msgctxt "235\t904097\t9\tCHK"
msgid "Drive, please!"
msgstr "Parta, la prego!"

msgctxt "235\t904112\t10\tCHK"
msgid "Eek!"
msgstr "Eek!"

msgctxt "235\t904117\t11\tCHK"
msgid "Come on, no need to be shy."
msgstr "Dai, non c'è bisogno di fare la timida."

msgctxt "235\t904145\t12\tCHK"
msgid "You could get hurt, sir."
msgstr "Potrebbe farsi male, signore."

msgctxt "235\t904170\t13\tCHK"
msgid "You're so cute when you get flustered!"
msgstr "Sei così carina quando ti agiti!"

msgctxt "235\t904209\t14\tCHK"
msgid "*sigh*"
msgstr "*Sigh*"

msgctxt "235\t904216\t15\tCHK"
msgid "I did warn you."
msgstr "Io l'avevo avvertita."

msgctxt "235\t904232\t16\tCHK"
msgid "Ngh!"
msgstr "Ngh!"

msgctxt "235\t904237\t17\tCHK"
msgid "Gahh!"
msgstr "Gahh!"

msgctxt "235\t904243\t18\tCHK"
msgid "Arrgh!"
msgstr "Arrgh!"

msgctxt "235\t904250\t19\tCHK"
msgid "Graah! *cough* *cough*"
msgstr "Graah! *Cof* *Cof*"

msgctxt "235\t904273\t20\tCHK"
msgid "Thank you!"
msgstr "Grazie!"

msgctxt "235\t904284\t21\tCHK"
msgid "Now, ladies and gentlemen!"
msgstr "E ora, signore e signori!"

msgctxt "235\t904311\t22\tCHK"
msgid "Witness a feat befitting the snow festival! "
msgstr "Ammirate un'impresa degna del festival della neve! "

msgctxt "235\t904356\t23\tCHK"
msgid "All right!"
msgstr "Va bene!"

msgctxt "235\t904367\t24\tCHK"
msgid "Whoa, holy crap!"
msgstr "Whoa, porca miseria!"

msgctxt "235\t904384\t25\tCHK"
msgid "Too fast! Too fast! Argh!"
msgstr "Troppo veloce! Troppo veloce! Argh!"

msgctxt "235\t904410\t26\tCHK"
msgid "Come on snowball!"
msgstr "Forza palla di neve!"

msgctxt "235\t904428\t27\tCHK"
msgid "Aaaahh!"
msgstr "Aaaahh!"

msgctxt "235\t904436\t28\tCHK"
msgid "Okay!"
msgstr "Okay!"

msgctxt "235\t904442\t29\tCHK"
msgid "Hah!"
msgstr "Hah!"

msgctxt "235\t904447\t30\tCHK"
msgid "Hmph! Hah!"
msgstr "Hmph! Hah!"

msgctxt "235\t904458\t31\tCHK"
msgid "Alright!"
msgstr "Molto bene!"

msgctxt "235\t904467\t32\tCHK"
msgid "Hyaah!"
msgstr "Hyaah!"

msgctxt "235\t904474\t33\tCHK"
msgid "And, bam!"
msgstr "E, bam!"

msgctxt "235\t904484\t34\tCHK"
msgid "Thanks for waitin'!"
msgstr "Grazie per l'attesa!"

msgctxt "235\t904504\t35\tCHK"
msgid "Wow! Looks tasty! Thanks!"
msgstr "Wow! Sembra delizioso! Grazie!"

msgctxt "235\t904530\t36\tCHK"
msgid "You can do that easy, right, buddy?"
msgstr "Tu riesci a farlo facile, vero, amico?"

msgctxt "235\t904566\t37\tCHK"
msgid "Nah, ain't no fun doin' the same thing."
msgstr "Nah, non c'è gusto a fare sempre la stessa cosa."

msgctxt "235\t904606\t38\tCHK"
msgid "We gotta cook two at a time or somethin'."
msgstr "Dobbiamo cuocerne due alla volta o robe simili."

msgctxt "235\t904648\t39\tCHK"
msgid "No sweat... Right!?"
msgstr "Una passeggiata... Giusto!?"

msgctxt "235\t904668\t40\tCHK"
msgid "T-Two at a time? I can't do that."
msgstr "D-Due alla volta? Non posso farcela."

msgctxt "235\t904702\t41\tCHK"
msgid "We ain't askin' chucklehead! Just shut your mouth and do it!"
msgstr "Non te l'abbiamo chiesto, idiota! Chiudi quella bocca e fallo!"

msgctxt "235\t904763\t42\tCHK"
msgid "Over here, everybody!"
msgstr "Tutti da questa parte!"

msgctxt "235\t904785\t43\tCHK"
msgid "We got an even better show in store for ya."
msgstr "Abbiamo uno spettacolo ancora più bello in serbo per voi."

msgctxt "235\t904829\t44\tCHK"
msgid "Go. Do it."
msgstr "Forza. Fallo."

msgctxt "235\t904840\t45\tCHK"
msgid "Uh... okay!"
msgstr "Ehm... okay!"

msgctxt "235\t904852\t46\tCHK"
msgid "Ain't they done yet?"
msgstr "Non sono ancora pronti?"

msgctxt "235\t904873\t47\tCHK"
msgid "Huh? I-I just put them on the hot plate."
msgstr "Eh? L-Li ho appena messi sulla piastra."

msgctxt "235\t904914\t48\tCHK"
msgid "Never mind that, do it!"
msgstr "Non importa, fallo e basta!"

msgctxt "235\t904938\t49\tCHK"
msgid "*whimper*"
msgstr "*Pagnisteo*"

msgctxt "235\t904948\t50\tCHK"
msgid "Come on."
msgstr "Forza."

msgctxt "235\t904957\t51\tCHK"
msgid "Now!"
msgstr "Adesso!"

msgctxt "235\t904962\t52\tCHK"
msgid "Here goes nothing!"
msgstr "O la va o la spacca!"

msgctxt "235\t904981\t53\tCHK"
msgid "Yah!"
msgstr "Yah!"

msgctxt "235\t904986\t54\tCHK"
msgid "Uh-oh..."
msgstr "Uh-oh..."

msgctxt "235\t904995\t55\tCHK"
msgid "The secrets to batting..."
msgstr "I segreti della battuta..."

msgctxt "235\t905021\t56\tCHK"
msgid "Keep eyes on the ball..."
msgstr "Tieni gli occhi sulla palla..."

msgctxt "235\t905046\t57\tCHK"
msgid "Get the right timing..."
msgstr "Prendi il giusto tempismo..."

msgctxt "235\t905070\t58\tCHK"
msgid "Hit with the sweet spot!"
msgstr "Colpisci nel punto perfetto!"

msgctxt "235\t905095\t59\tCHK"
msgid "Heh... That's how it's done."
msgstr "Eheh... Ecco come si fa."

msgctxt "235\t905124\t60\tCHK"
msgid "Okay, everyone!"
msgstr "Okay, gente!"

msgctxt "235\t905140\t61\tCHK"
msgid "This top idol is going to show you how dancing is done!"
msgstr "Questa idol di prim'ordine vi mostrerà come si balla!"

msgctxt "235\t905196\t62\tCHK"
msgid "She can move, all right. Ha ha ha!"
msgstr "Sa decisamente muoversi. Ah ah ah!"

msgctxt "235\t905231\t63\tCHK"
msgid "Try to keep up!"
msgstr "Cercate di starmi dietro!"

msgctxt "235\t905247\t64\tCHK"
msgid "*pant* *pant*"
msgstr "*Anf* *anf*"

msgctxt "235\t905261\t65\tCHK"
msgid "Too fast, too fast... Ack!"
msgstr "Troppo veloce, troppo veloce... Ack!"

msgctxt "235\t905288\t66\tCHK"
msgid "Hey, hold on a second..."
msgstr "Ehi, aspettate un secondo..."

msgctxt "235\t905313\t67\tCHK"
msgid "I've got a special trick to show you!"
msgstr "Ho un trucco speciale da mostrarvi!"

msgctxt "235\t905351\t68\tCHK"
msgid "Haaaah!"
msgstr "Haaaah!"

msgctxt "235\t905359\t69\tCHK"
msgid "Whaaaah!"
msgstr "Whaaaah!"

msgctxt "235\t905368\t70\tCHK"
msgid "Whoooa!"
msgstr "Whoooa!"

msgctxt "235\t905376\t71\tCHK"
msgid "Huh?"
msgstr "Eh?"

msgctxt "235\t905381\t72\tCHK"
msgid "Thanks everyone! See! I'm a true superstar!"
msgstr "Grazie a tutti! Visto! Sono una vera superstar!"

msgctxt "235\t905425\t73\tCHK"
msgid "Ahhh!"
msgstr "Ahhh!"

msgctxt "235\t905431\t74\tCHK"
msgid "Hey! Hey! She fell!"
msgstr "Ehi! Ehi! È caduta!"

msgctxt "235\t905451\t75\tCHK"
msgid "She all right?"
msgstr "Sta bene?"

msgctxt "235\t905466\t76\tCHK"
msgid ""
"Saejima! Looks like you're even\n"
"tougher than I thought!"
msgstr ""
"Saejima! Sembra che tu sia persino\n"
"più tosto di quanto pensassi!"

msgctxt "235\t905522\t77\tCHK"
msgid ""
"But all that hard work's about\n"
"to come to nothing."
msgstr ""
"Ma tutto questo duro lavoro sta per\n"
"risolversi in un bel niente."

msgctxt "235\t905573\t78\tCHK"
msgid ""
"My new friends'll be showing\n"
"up any minute now."
msgstr ""
"I miei nuovi amici si faranno\n"
"vivi da un momento all'altro."

msgctxt "235\t905621\t79\tCHK"
msgid ""
"You can try to break out,\n"
"but you'll never escape us."
msgstr ""
"Puoi provare a scappare,\n"
"ma non ci sfuggirai mai."

msgctxt "235\t905675\t80\tCHK"
msgid "Now get ready to die, Saejima!"
msgstr "Ora preparati a morire, Saejima!"

msgctxt "235\t905706\t81\tCHK"
msgid ""
"We need to get through this\n"
"storm as fast as possible!"
msgstr ""
"Dobbiamo superare questa tempesta\n"
"il più velocemente possibile!"

msgctxt "235\t905761\t82\tCHK"
msgid "Hang on tight, Baba-chan!"
msgstr "Tieniti forte, Baba-chan!"

msgctxt "235\t905787\t83\tCHK"
msgid "Okay, let's start our champagne tower!"
msgstr "Okay, iniziamo la nostra torre di champagne!"

msgctxt "235\t905826\t84\tCHK"
msgid "Wow, so pretty!"
msgstr "Wow, che bella!"

msgctxt "235\t905842\t85\tCHK"
msgid "And that's it! Thank you! Let's hear some applause!"
msgstr "E questo è tutto! Grazie! Facciamo un bell'applauso!"

msgctxt "235\t905894\t86\tCHK"
msgid "Wow! It's so amazing!"
msgstr "Wow! È fantastica!"

msgctxt "235\t905916\t87\tCHK"
msgid "Whoa... Amazing!"
msgstr "Whoa... Fantastica!"

msgctxt "235\t905933\t88\tCHK"
msgid "Now how about we get this champagne tower started!"
msgstr "Ora che ne dite di iniziare questa torre di champagne!"

msgctxt "235\t905984\t89\tCHK"
msgid "Wow... That sure is pretty!"
msgstr "Wow... È davvero bellissima!"

msgctxt "235\t906012\t90\tCHK"
msgid "Wow... Amazing!"
msgstr "Wow... Straordinaria!"

msgctxt "235\t906028\t91\tCHK"
msgid "Wow, beautiful!"
msgstr "Wow, meravigliosa!"

msgctxt "235\t906044\t92\tCHK"
msgid "Damn! That idiot Kugihara didn't finish the job!"
msgstr "Dannazione! Quell'idiota di Kugihara non ha finito il lavoro!"

msgctxt "235\t906093\t93\tCHK"
msgid "C'mon, boys!"
msgstr "Forza, ragazzi!"

msgctxt "235\t906106\t94\tCHK"
msgid "We can't let them get away!"
msgstr "Non possiamo lasciarli scappare!"
