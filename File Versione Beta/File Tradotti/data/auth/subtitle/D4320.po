msgctxt "118\t227\t109\t\t \t "
msgid "Sakai-san. Please, I need you to tell me."
msgstr "Sakai-san. La prego, deve dirmelo."

msgctxt "292\t352\t60\t　\t　\t "
msgid "What was the point of all this?"
msgstr "Che senso ha avuto tutto questo?"

msgctxt "384\t569\t185\t　\t　\t "
msgid ""
"Back when you got called up...\r"
"\r\n"
"You landed in the wrong place at the wrong time."
msgstr ""
"Quando ti hanno chiamato in prima squadra...\n"
"Sei capitato nel posto sbagliato al momento sbagliato."

msgctxt "597\t798\t201\t　\t　\t "
msgid ""
"You were the only one on the team who\r"
"\r\n"
"didn't know the truth. It was so convenient."
msgstr ""
"Eri l'unico in squadra a\n"
"non sapere la verità. Era così comodo."

msgctxt "866\t927\t61\t　\t　\t "
msgid "You should know, Shinada..."
msgstr "Devi saperlo, Shinada..."

msgctxt "941\t1025\t84\t分\t　\t "
msgid "I think we did you wrong."
msgstr "Credo che ti abbiamo fatto un torto."

msgctxt "1047\t1203\t156\t　\t　\t "
msgid ""
"But I've never regretted sacrificing you.\r"
"\r\n"
"Not for a second."
msgstr ""
"Ma non mi sono mai pentito di averti sacrificato.\n"
"Nemmeno per un secondo."

msgctxt "1215\t1275\t60\t　\t　\t "
msgid "What do you mean?"
msgstr "Cosa intende?"

msgctxt "1318\t1447\t129\t　\t　\t "
msgid ""
"We threw you to the wolves,\r"
"\r\n"
"for the good of Nagoya."
msgstr ""
"Ti abbiamo dato in pasto ai lupi,\n"
"per il bene di Nagoya."

msgctxt "1470\t1567\t97\t　\t　\t "
msgid ""
"For the good of Nagoya?\r"
"\r\n"
"How's that make sense?"
msgstr ""
"Per il bene di Nagoya?\n"
"Che senso ha?"

msgctxt "1632\t1692\t60\t　\t　\t "
msgid "What are you talking about!?"
msgstr "Ma di cosa sta parlando!?"

msgctxt "1718\t1781\t63\t分\t　\t "
msgid "Give it to me straight, Sakai-san!"
msgstr "Mi dica le cose come stanno, Sakai-san!"

msgctxt "1824\t1884\t60\t　\t　\t "
msgid "Well..."
msgstr "Beh..."

msgctxt "2135\t2195\t60\t　\t　\t "
msgid "Sakai-san!"
msgstr "Sakai-san!"

msgctxt "2210\t2270\t60\t　\t　\t "
msgid "Sakai-san! Hey!"
msgstr "Sakai-san! Ehi!"

msgctxt "2332\t2379\t47\t　\t　\t60ｆ以下です"
msgid "No use."
msgstr "È inutile."

msgctxt "2380\t2440\t60\t　\t　\t "
msgid "He's gone."
msgstr "Non c'è più."

msgctxt "2568\t2699\t131\t　\t　\t "
msgid "They sacrificed me... for Nagoya?"
msgstr "Mi hanno sacrificato... per Nagoya?"

msgctxt "2734\t2812\t78\t分\t　\t "
msgid "What did he mean by that?"
msgstr "Cosa voleva dire con questo?"
